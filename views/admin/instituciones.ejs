            <!-- Create Institution Form -->
            <div class="dashboard-card">
                <h2><i class="material-icons">add</i> Nueva Institución</h2>
                <form>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Nombre de la Institución *</label>
                            <input type="text" class="form-control" placeholder="Ej: Universidad Nacional" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Tipo de Institución *</label>
                            <select class="form-control" required>
                                <option value="">Selecciona el tipo</option>
                                <option value="educational">Educativa</option>
                                <option value="corporate">Corporativa</option>
                                <option value="government">Gubernamental</option>
                                <option value="ngo">ONG / Fundación</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Email Institucional *</label>
                            <input type="email" class="form-control" placeholder="contacto@institucion.com" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Teléfono</label>
                            <input type="tel" class="form-control" placeholder="+52 555 123 4567">
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Plan Suscripción *</label>
                            <select class="form-control" required>
                                <option value="">Selecciona el plan</option>
                                <option value="basic">Básico - $29/mes</option>
                                <option value="professional">Profesional - $99/mes</option>
                                <option value="enterprise">Empresarial - $299/mes</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Número de Usuarios Estimado</label>
                            <input type="number" class="form-control" placeholder="100" min="1">
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Descripción</label>
                        <textarea class="form-control" rows="3" placeholder="Describe la institución y sus necesidades educativas..."></textarea>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Dirección</label>
                        <input type="text" class="form-control" placeholder="Calle, Número, Ciudad, País">
                    </div>

                    <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px; margin-bottom: 2rem;">
                        <h3 style="margin-bottom: 1rem;"><i class="material-icons">settings</i> Configuración de la Institución</h3>
                        <label style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">Acceso a Todos los Cursos</div>
                                <div style="font-size: 0.9rem; color: #666;">Permitir acceso al catálogo completo</div>
                            </div>
                            <input type="checkbox" checked style="width: 20px; height: 20px;">
                        </label>
                        <label style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">Cursos Personalizados</div>
                                <div style="font-size: 0.9rem; color: #666;">Permitir creación de cursos exclusivos</div>
                            </div>
                            <input type="checkbox" style="width: 20px; height: 20px;">
                        </label>
                        <label style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">Reportes Avanzados</div>
                                <div style="font-size: 0.9rem; color: #666;">Acceso a analytics detallados</div>
                            </div>
                            <input type="checkbox" checked style="width: 20px; height: 20px;">
                        </label>
                        <label style="display: flex; align-items: center; justify-content: space-between;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">Soporte Prioritario</div>
                                <div style="font-size: 0.9rem; color: #666;">Atención preferencial y dedicada</div>
                            </div>
                            <input type="checkbox" checked style="width: 20px; height: 20px;">
                        </label>
                    </div>

                    <div style="text-align: right;">
                        <button type="button" class="btn btn-outline" style="margin-right: 1rem;">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Crear Institución</button>
                    </div>
                </form>
            </div>

