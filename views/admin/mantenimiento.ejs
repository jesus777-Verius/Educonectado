            <!-- Create Maintenance Task -->
            <div class="dashboard-card">
                <h2><i class="material-icons">add</i> Programar Nueva Tarea de Mantenimiento</h2>
                <form>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Nombre de la Tarea *</label>
                            <input type="text" class="form-control" placeholder="Ej: Actualización de seguridad" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Tipo de Tarea *</label>
                            <select class="form-control" required>
                                <option value="">Selecciona el tipo</option>
                                <option value="update">Actualización</option>
                                <option value="backup">Backup</option>
                                <option value="cleanup">Limpieza</option>
                                <option value="optimization">Optimización</option>
                                <option value="security">Seguridad</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Fecha de Ejecución *</label>
                            <input type="datetime-local" class="form-control" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Duración Estimada (minutos)</label>
                            <input type="number" class="form-control" placeholder="60" min="5" max="480">
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Nivel de Impacto *</label>
                            <select class="form-control" required>
                                <option value="">Selecciona el impacto</option>
                                <option value="minimal">Mínimo (sin interrupción)</option>
                                <option value="low">Bajo (breve interrupción)</option>
                                <option value="medium">Medio (interrupción parcial)</option>
                                <option value="high">Alto (interrupción total)</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Frecuencia</label>
                            <select class="form-control">
                                <option value="once">Una vez</option>
                                <option value="daily">Diario</option>
                                <option value="weekly">Semanal</option>
                                <option value="monthly">Mensual</option>
                                <option value="custom">Personalizado</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Descripción de la Tarea</label>
                        <textarea class="form-control" rows="3" placeholder="Describe detalladamente la tarea de mantenimiento..."></textarea>
                    </div>

                    <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px; margin-bottom: 2rem;">
                        <h3 style="margin-bottom: 1rem;"><i class="material-icons">settings</i> Configuración de Notificaciones</h3>
                        <label style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">Notificar a Administradores</div>
                                <div style="font-size: 0.9rem; color: #666;">Enviar notificación antes de la ejecución</div>
                            </div>
                            <input type="checkbox" checked style="width: 20px; height: 20px;">
                        </label>
                        <label style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">Notificar a Usuarios</div>
                                <div style="font-size: 0.9rem; color: #666;">Mostrar aviso de mantenimiento en la plataforma</div>
                            </div>
                            <input type="checkbox" style="width: 20px; height: 20px;">
                        </label>
                        <label style="display: flex; align-items: center; justify-content: space-between;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">Confirmación de Ejecución</div>
                                <div style="font-size: 0.9rem; color: #666;">Requerir confirmación manual antes de ejecutar</div>
                            </div>
                            <input type="checkbox" checked style="width: 20px; height: 20px;">
                        </label>
                    </div>

                    <div style="text-align: right;">
                        <button type="button" class="btn btn-outline" style="margin-right: 1rem;">Cancelar</button>
                        <button type="submit" class="btn btn-primary"><i class="material-icons">calendar_today</i> Programar Tarea</button>
                    </div>
                </form>
            </div>

