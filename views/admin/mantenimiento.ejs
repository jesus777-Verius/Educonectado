                                <td style="padding: 1rem; text-align: center;">
                                    <div style="display: flex; align-items: center; gap: 0.5rem; justify-content: center;">
                                        <img src="https://via.placeholder.com/24x24/dc3545/ffffff?text=A" alt="Admin" style="width: 24px; height: 24px; border-radius: 50%;">
                                        <span style="font-size: 0.9rem;">Admin</span>
                                    </div>
                                </td>
                                <td style="padding: 1rem; text-align: center;">
                                    <span style="background: #28a745; color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.8rem;">Exitoso</span>
                                </td>
                                <td style="padding: 1rem; text-align: center;">
                                    <div style="display: flex; gap: 0.5rem; justify-content: center;">
                                        <button class="btn btn-outline" style="font-size: 0.8rem;">Ver Log</button>
                                        <button class="btn btn-outline" style="font-size: 0.8rem;">Revertir</button>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- System Logs -->
            <div class="dashboard-card">
                <h2><i class="material-icons">edit</i> Logs del Sistema</h2>
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
                    <div style="display: flex; gap: 1rem;">
                        <select class="form-control" style="width: 150px;">
                            <option value="all">Todos los logs</option>
                            <option value="error">Errores</option>
                            <option value="warning">Advertencias</option>
                            <option value="info">Información</option>
                            <option value="debug">Debug</option>
                        </select>
                        <input type="date" class="form-control" style="width: 150px;" value="2024-11-29">
                        <button class="btn btn-outline"><i class="material-icons">refresh</i> Actualizar</button>
                    </div>
                    <button class="btn btn-outline">📥 Descargar Logs</button>
                </div>

                <div style="background: #1e1e1e; color: #fff; padding: 1rem; border-radius: 8px; font-family: monospace; font-size: 0.9rem; max-height: 400px; overflow-y: auto;">
                    <div style="margin-bottom: 0.5rem;">
                        <span style="color: #6c757d;">[2024-11-29 10:23:45]</span>
                        <span style="color: #28a745;"> [INFO]</span>
                        <span> Sistema iniciado correctamente</span>
                    </div>
                    <div style="margin-bottom: 0.5rem;">
                        <span style="color: #6c757d;">[2024-11-29 10:15:32]</span>
                        <span style="color: #ffc107;"> [WARNING]</span>
                        <span> Alta carga en CPU: 78%</span>
                    </div>
                    <div style="margin-bottom: 0.5rem;">
                        <span style="color: #6c757d;">[2024-11-29 10:10:18]</span>
                        <span style="color: #28a745;"> [INFO]</span>
                        <span> Backup automático completado exitosamente</span>
                    </div>
                    <div style="margin-bottom: 0.5rem;">
                        <span style="color: #6c757d;">[2024-11-29 09:45:23]</span>
                        <span style="color: #dc3545;"> [ERROR]</span>
                        <span> Conexión a base de datos fallida: Timeout</span>
                    </div>
                    <div style="margin-bottom: 0.5rem;">
                        <span style="color: #6c757d;">[2024-11-29 09:30:45]</span>
                        <span style="color: #28a745;"> [INFO]</span>
                        <span> Usuario Admin Sistema inició sesión</span>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="dashboard-card">
                <h2>⚡ Acciones Rápidas</h2>
                <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
                    <button class="btn btn-primary"><i class="material-icons">refresh</i> Reiniciar Sistema</button>
                    <button class="btn btn-outline">🧹 Limpiar Cache</button>
                    <button class="btn btn-outline"><i class="material-icons">backup</i> Backup Manual</button>
                    <button class="btn btn-outline"><i class="material-icons">bar_chart</i> Ver Métricas</button>
                    <button class="btn btn-outline"><i class="material-icons">edit</i> Ver Logs</button>
                    <button class="btn btn-outline"><i class="material-icons">settings</i> Optimizar Sistema</button>
                </div>
            </div>
        </main>
    </div>

    <!-- Footer -->
    <footer class="dashboard-footer">
        <div class="container">
            <p>&copy; 2024 EduConecta. Panel Administrativo</p>
        </div>
    </footer>
</body>
