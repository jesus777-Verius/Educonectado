            <!-- Create Ticket Form -->
            <div class="dashboard-card">
                <h2><i class="material-icons">add</i> Crear Nuevo Ticket</h2>
                <form>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Usuario *</label>
                            <select class="form-control" required>
                                <option value="">Selecciona un usuario</option>
                                <option value="user1">Juan Pérez - juan.perez@email.com</option>
                                <option value="user2">María González - maria.gonzalez@email.com</option>
                                <option value="user3">Ana Rodríguez - ana.rodriguez@email.com</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Categoría *</label>
                            <select class="form-control" required>
                                <option value="">Selecciona la categoría</option>
                                <option value="technical">Técnico</option>
                                <option value="billing">Facturación</option>
                                <option value="account">Cuenta</option>
                                <option value="course">Curso</option>
                                <option value="other">Otro</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Prioridad *</label>
                            <select class="form-control" required>
                                <option value="">Selecciona la prioridad</option>
                                <option value="urgent">Urgente</option>
                                <option value="high">Alta</option>
                                <option value="medium">Media</option>
                                <option value="low">Baja</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Asignar a Agente</label>
                            <select class="form-control">
                                <option value="">Sin asignar</option>
                                <option value="agent1">Sofía Martínez</option>
                                <option value="agent2">Carlos Rodríguez</option>
                                <option value="agent3">Laura Sánchez</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Asunto *</label>
                        <input type="text" class="form-control" placeholder="Describe brevemente el problema" required>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Descripción Detallada *</label>
                        <textarea class="form-control" rows="5" placeholder="Describe el problema en detalle, incluyendo pasos para reproducirlo si es aplicable..." required></textarea>
                    </div>

                    <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px; margin-bottom: 2rem;">
                        <h3 style="margin-bottom: 1rem;"><i class="material-icons">assignment</i> Información Adicional</h3>
                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">Navegador</label>
                                <select class="form-control">
                                    <option value="">No especificado</option>
                                    <option value="chrome">Chrome</option>
                                    <option value="firefox">Firefox</option>
                                    <option value="safari">Safari</option>
                                    <option value="edge">Edge</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Dispositivo</label>
                                <select class="form-control">
                                    <option value="">No especificado</option>
                                    <option value="desktop">Desktop</option>
                                    <option value="mobile">Móvil</option>
                                    <option value="tablet">Tablet</option>
                                </select>
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">URL donde ocurrió el problema</label>
                            <input type="url" class="form-control" placeholder="https://educonecta.com/...">
                        </div>
                    </div>

                    <div style="text-align: right;">
                        <button type="button" class="btn btn-outline" style="margin-right: 1rem;">Cancelar</button>
                        <button type="submit" class="btn btn-primary"><i class="material-icons">assignment</i> Crear Ticket</button>
                    </div>
                </form>
            </div>

