                                <span style="font-size: 0.9rem;">Impuestos (16%)</span>
                                <span style="font-weight: bold; color: #667eea;">$12.00</span>
                            </div>
                        </div>
                        <div style="border-top: 1px solid #ddd; padding-top: 1rem;">
                            <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                <span style="font-weight: bold;">Total a Pagar</span>
                                <span style="font-weight: bold; color: #28a745; font-size: 1.2rem;">$87.00</span>
                            </div>
                        </div>
                    </div>

                    <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px; margin-bottom: 2rem;">
                        <h3 style="margin-bottom: 1rem;"><i class="material-icons">settings</i> Configuración de la Matrícula</h3>
                        <label style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">Acceso Inmediato</div>
                                <div style="font-size: 0.9rem; color: #666;">Permitir acceso al curso inmediatamente</div>
                            </div>
                            <input type="checkbox" checked style="width: 20px; height: 20px;">
                        </label>
                        <label style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">Enviar Certificado al Finalizar</div>
                                <div style="font-size: 0.9rem; color: #666;">Generar certificado automáticamente</div>
                            </div>
                            <input type="checkbox" checked style="width: 20px; height: 20px;">
                        </label>
                        <label style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">Recordatorios de Progreso</div>
                                <div style="font-size: 0.9rem; color: #666;">Enviar notificaciones periódicas</div>
                            </div>
                            <input type="checkbox" checked style="width: 20px; height: 20px;">
                        </label>
                        <label style="display: flex; align-items: center; justify-content: space-between;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">Extensión Automática</div>
                                <div style="font-size: 0.9rem; color: #666;">Extender acceso si no completa a tiempo</div>
                            </div>
                            <input type="checkbox" style="width: 20px; height: 20px;">
                        </label>
                    </div>

                    <div style="text-align: right;">
                        <button type="button" class="btn btn-outline" style="margin-right: 1rem;">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Crear Matrícula</button>
                    </div>
                </form>
