                        <div style="margin-bottom: 1rem;">
                            <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                <span style="font-size: 0.9rem;">Costo del Curso</span>
                                <span style="font-weight: bold; color: #667eea;">$75.00</span>
                            </div>
                        </div>
                        <div style="margin-bottom: 1rem;">
                            <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                <span style="font-size: 0.9rem;">Descuento</span>
                                <span style="font-weight: bold; color: #dc3545;">-$0.00</span>
                            </div>
                        </div>
                        <div style="margin-bottom: 1rem;">
