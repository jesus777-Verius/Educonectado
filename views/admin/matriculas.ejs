                                <option value="">Selecciona un estudiante</option>
                                <option value="student1">Juan Pérez - juan.perez@email.com</option>
                                <option value="student2">María González - maria.gonzalez@email.com</option>
                                <option value="student3">Carlos Méndez - carlos.mendez@email.com</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Curso *</label>
                            <select class="form-control" required>
                                <option value="">Selecciona un curso</option>
                                <option value="marketing">Marketing Digital - $50</option>
                                <option value="programming">Programación Web - $75</option>
                                <option value="business">Gestión Empresarial - $60</option>
                                <option value="design">Diseño Gráfico - $80</option>
                            </select>
                        </div>
                    </div>

