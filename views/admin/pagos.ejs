            <!-- Payment Processing Form -->
            <div class="dashboard-card">
                <h2>💳 Procesar Nuevo Pago</h2>
                <form>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Cliente *</label>
                            <select class="form-control" required>
                                <option value="">Selecciona un cliente</option>
                                <option value="customer1">Juan Pérez - juan.perez@email.com</option>
                                <option value="customer2">María González - maria.gonzalez@email.com</option>
                                <option value="customer3">TechCorp Solutions - corporativo</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Tipo de Pago *</label>
                            <select class="form-control" required>
                                <option value="">Selecciona el tipo</option>
                                <option value="course">Matrícula de Curso</option>
                                <option value="subscription">Suscripción</option>
                                <option value="certificate">Certificado</option>
                                <option value="renewal">Renovación</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Método de Pago *</label>
                            <select class="form-control" required>
                                <option value="">Selecciona el método</option>
                                <option value="card">Tarjeta de Crédito/Débito</option>
                                <option value="transfer">Transferencia Bancaria</option>
                                <option value="paypal">PayPal</option>
                                <option value="cash">Efectivo</option>
                                <option value="corporate">Facturación Corporativa</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Monto *</label>
                            <input type="number" class="form-control" placeholder="0.00" step="0.01" min="0" required>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Descripción del Pago</label>
                        <textarea class="form-control" rows="3" placeholder="Describe el concepto del pago..."></textarea>
                    </div>

                    <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px; margin-bottom: 2rem;">
                        <h3 style="margin-bottom: 1rem;">💳 Información de Pago</h3>
                        <div id="card-info" style="display: block;">
                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label">Número de Tarjeta</label>
                                    <input type="text" class="form-control" placeholder="1234 5678 9012 3456" maxlength="19">
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Nombre del Titular</label>
                                    <input type="text" class="form-control" placeholder="Juan Pérez">
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label">Fecha de Vencimiento</label>
                                    <input type="text" class="form-control" placeholder="MM/AA" maxlength="5">
                                </div>
                                <div class="form-group">
                                    <label class="form-label">CVV</label>
                                    <input type="text" class="form-control" placeholder="123" maxlength="4">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px; margin-bottom: 2rem;">
                        <h3 style="margin-bottom: 1rem;"><i class="material-icons">description</i> Opciones de Facturación</h3>
                        <label style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">Generar Factura</div>
                                <div style="font-size: 0.9rem; color: #666;">Crear factura fiscal automáticamente</div>
                            </div>
                            <input type="checkbox" checked style="width: 20px; height: 20px;">
                        </label>
                        <label style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">Enviar Email de Confirmación</div>
                                <div style="font-size: 0.9rem; color: #666;">Notificar al cliente sobre el pago</div>
                            </div>
                            <input type="checkbox" checked style="width: 20px; height: 20px;">
                        </label>
                        <label style="display: flex; align-items: center; justify-content: space-between;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">Guardar Método de Pago</div>
                                <div style="font-size: 0.9rem; color: #666;">Para futuros pagos recurrentes</div>
                            </div>
                            <input type="checkbox" style="width: 20px; height: 20px;">
                        </label>
                    </div>

                    <div style="text-align: right;">
                        <button type="button" class="btn btn-outline" style="margin-right: 1rem;">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Procesar Pago</button>
                    </div>
                </form>
            </div>

