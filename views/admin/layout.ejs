<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - EduConecta Admin</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
    <!-- Dashboard Header -->
    <header class="dashboard-header">
        <div class="container">
            <div class="dashboard-nav">
                <div class="nav-left">
                    <a href="/" class="logo"><i class="material-icons" style="vertical-align: middle; margin-right: 8px;">school</i> EduConecta</a>
                    <span class="user-role">Administrador</span>
                </div>
                <div class="nav-right">
                    <div class="notifications">
                        <button class="btn-icon"><i class="material-icons">notifications</i> <span class="badge">12</span></button>
                    </div>
                    <div class="user-menu">
                        <img src="https://via.placeholder.com/40x40/dc3545/ffffff?text=A" alt="Usuario" class="user-avatar">
                        <span>Admin Sistema</span>
                        <div class="dropdown">
                            <a href="/admin/perfil">Mi Perfil</a>
                            <a href="/admin/configuracion">Configuración</a>
                            <a href="/admin/soporte">Soporte</a>
                            <a href="/logout">Cerrar Sesión</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Dashboard Content -->
    <div class="dashboard-container">
        <!-- Sidebar -->
        <aside class="dashboard-sidebar">
            <nav class="sidebar-nav">
                <ul>
                    <li><a href="/admin/dashboard"><i class="material-icons">dashboard</i> Dashboard</a></li>
                    <li><a href="/admin/usuarios"><i class="material-icons">people</i> Usuarios</a></li>
                    <li><a href="/admin/cursos"><i class="material-icons">menu_book</i> Cursos</a></li>
                    <li><a href="/admin/instituciones"><i class="material-icons">business</i> Instituciones</a></li>
                    <li><a href="/admin/matriculas"><i class="material-icons">assignment</i> Matrículas</a></li>
                    <li><a href="/admin/pagos"><i class="material-icons">payments</i> Pagos</a></li>
                    <li><a href="/admin/reportes"><i class="material-icons">assessment</i> Reportes</a></li>
                    <li><a href="/admin/configuracion-sistema"><i class="material-icons">settings</i> Configuración</a></li>
                    <li><a href="/admin/seguridad"><i class="material-icons">security</i> Seguridad</a></li>
                    <li><a href="/admin/soporte-admin"><i class="material-icons">support_agent</i> Soporte</a></li>
                    <li><a href="/admin/auditoria"><i class="material-icons">fact_check</i> Auditoría</a></li>
                    <li><a href="/admin/mantenimiento"><i class="material-icons">build</i> Mantenimiento</a></li>
                    <li><a href="/admin/notificaciones"><i class="material-icons">campaign</i> Notificaciones</a></li>
                    <li><a href="/admin/integraciones"><i class="material-icons">integration_instructions</i> Integraciones</a></li>
                    <li><a href="/admin/backup"><i class="material-icons">backup</i> Backup</a></li>
                </ul>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="dashboard-main">
            <!-- Flash Messages -->
            <% if (typeof messages !== 'undefined' && messages.error) { %>
                <div class="flash-message error">
                    <%= messages.error %>
                </div>
            <% } %>
            <% if (typeof messages !== 'undefined' && messages.success) { %>
                <div class="flash-message success">
                    <%= messages.success %>
                </div>
            <% } %>
            <% if (typeof messages !== 'undefined' && messages.info) { %>
                <div class="flash-message info">
                    <%= messages.info %>
                </div>
            <% } %>

            <!-- Dynamic Content -->
            <%- body %>
        </main>
    </div>

    <!-- Footer -->
    <footer class="dashboard-footer">
        <div class="container">
            <p>&copy; 2024 EduConecta. Panel Administrativo</p>
        </div>
    </footer>
</body>
</html>
