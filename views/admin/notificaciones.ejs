                    <div class="stat-info">
                        <h3>3,456</h3>
                        <p>Notificaciones Enviadas Hoy</p>
                        <div style="font-size: 0.8rem; color: #28a745;">↑ 15% vs ayer</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon green"><i class="material-icons">check_circle</i></div>
                    <div class="stat-info">
                        <h3>89%</h3>
                        <p>Tasa de Apertura</p>
                        <div style="font-size: 0.8rem; color: #667eea;">Promedio mensual</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon orange"><i class="material-icons">phone</i></div>
                    <div class="stat-info">
                        <h3>1,234</h3>
                        <p>Notificaciones Push</p>
                        <div style="font-size: 0.8rem; color: #ffc107;">Últimas 24 horas</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon red"><i class="material-icons">warning</i></div>
                    <div class="stat-info">
