                            </div>
                            <div style="margin-bottom: 1rem;">
                                <div style="font-size: 0.8rem; color: #666;">
                                    <span><i class="material-icons">email</i> Email + Push + SMS</span>
                                    <span style="margin-left: 1rem;">👁️ 156 usos</span>
                                    <span style="margin-left: 1rem;"><i class="material-icons">star</i> 4.9/5</span>
                                </div>
                            </div>
                            <button class="btn btn-outline" style="width: 100%;">Usar Plantilla</button>
                        </div>
                    </div>
                </div>
            </div>

