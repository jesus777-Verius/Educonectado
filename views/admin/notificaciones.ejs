                <div style="overflow-x: auto;">
                    <table style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="background: #f8f9fa;">
                                <th style="padding: 1rem; text-align: left;">Notificación</th>
                                <th style="padding: 1rem; text-align: center;">Tipo</th>
                                <th style="padding: 1rem; text-align: center;">Audiencia</th>
                                <th style="padding: 1rem; text-align: center;">Enviado</th>
