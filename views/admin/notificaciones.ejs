            </div>

            <!-- Create Notification -->
            <div class="dashboard-card">
                <h2><i class="material-icons">add</i> Crear Nueva Notificación</h2>
                <form>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Tipo de Notificación *</label>
                            <select class="form-control" required>
                                <option value="">Selecciona el tipo</option>
                                <option value="general">General</option>
                                <option value="course">Curso</option>
                                <option value="payment">Pago</option>
                                <option value="system">Sistema</option>
                                <option value="marketing">Marketing</option>
                                <option value="urgent">Urgente</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Audiencia *</label>
                            <select class="form-control" required>
                                <option value="">Selecciona la audiencia</option>
                                <option value="all">Todos los usuarios</option>
                                <option value="students">Solo estudiantes</option>
                                <option value="teachers">Solo docentes</option>
                                <option value="admins">Solo administradores</option>
                                <option value="custom">Personalizado</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Título *</label>
                            <input type="text" class="form-control" placeholder="Título de la notificación" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Prioridad</label>
                            <select class="form-control">
                                <option value="low">Baja</option>
                                <option value="medium" selected>Media</option>
                                <option value="high">Alta</option>
                                <option value="urgent">Urgente</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Mensaje *</label>
                        <textarea class="form-control" rows="4" placeholder="Escribe el mensaje de la notificación..." required></textarea>
                    </div>

                    <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px; margin-bottom: 2rem;">
                        <h3 style="margin-bottom: 1rem;"><i class="material-icons">email</i> Canales de Envío</h3>
                        <label style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">Email</div>
                                <div style="font-size: 0.9rem; color: #666;">Enviar notificación por correo electrónico</div>
                            </div>
                            <input type="checkbox" checked style="width: 20px; height: 20px;">
                        </label>
                        <label style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">Notificaciones Push</div>
                                <div style="font-size: 0.9rem; color: #666;">Enviar notificación al dispositivo móvil</div>
                            </div>
                            <input type="checkbox" checked style="width: 20px; height: 20px;">
                        </label>
                        <label style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">SMS</div>
                                <div style="font-size: 0.9rem; color: #666;">Enviar mensaje de texto (solo urgente)</div>
                            </div>
                            <input type="checkbox" style="width: 20px; height: 20px;">
                        </label>
                        <label style="display: flex; align-items: center; justify-content: space-between;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">Notificación en Plataforma</div>
                                <div style="font-size: 0.9rem; color: #666;">Mostrar en el panel de notificaciones</div>
                            </div>
                            <input type="checkbox" checked style="width: 20px; height: 20px;">
                        </label>
                    </div>

                    <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px; margin-bottom: 2rem;">
                        <h3 style="margin-bottom: 1rem;"><i class="material-icons">schedule</i> Programación de Envío</h3>
                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">Fecha de Envío</label>
                                <input type="datetime-local" class="form-control">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Envío Recurrente</label>
                                <select class="form-control">
                                    <option value="no">No</option>
                                    <option value="daily">Diario</option>
                                    <option value="weekly">Semanal</option>
                                    <option value="monthly">Mensual</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div style="text-align: right;">
                        <button type="button" class="btn btn-outline" style="margin-right: 1rem;"><i class="material-icons">assignment</i> Vista Previa</button>
                        <button type="button" class="btn btn-outline" style="margin-right: 1rem;">Cancelar</button>
                        <button type="submit" class="btn btn-primary"><i class="material-icons">email</i> Enviar Notificación</button>
                    </div>
                </form>
            </div>

