<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Administrativo - EduConecta</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
    <!-- Dashboard Header -->
    <header class="dashboard-header">
        <div class="container">
            <div class="dashboard-nav">
                <div class="nav-left">
                    <a href="/" class="logo"><i class="material-icons">menu_book</i> EduConecta</a>
                    <span class="user-role">Administrador</span>
                </div>
                <div class="nav-right">
                    <div class="notifications">
                        <button class="btn-icon"><i class="material-icons">notifications</i> <span class="badge">12</span></button>
                    </div>
                    <div class="user-menu">
                        <img src="https://via.placeholder.com/40x40/dc3545/ffffff?text=A" alt="Usuario" class="user-avatar">
                        <span><%= user.nombres %> <%= user.apellidos %></span>
                        <div class="dropdown">
                            <a href="/admin/perfil">Mi Perfil</a>
                            <a href="/admin/configuracion">Configuración</a>
                            <a href="/admin/soporte">Soporte</a>
                            <a href="/logout">Cerrar Sesión</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Dashboard Content -->
    <div class="dashboard-container">
        <!-- Sidebar -->
        <aside class="dashboard-sidebar">
            <nav class="sidebar-nav">
                <ul>
                    <li><a href="/admin/dashboard" class="active"><i class="material-icons">bar_chart</i> Dashboard</a></li>
                    <li><a href="/admin/usuarios"><i class="material-icons">people</i> Usuarios</a></li>
                    <li><a href="/admin/cursos"><i class="material-icons">menu_book</i> Cursos</a></li>
                    <li><a href="/admin/instituciones"><i class="material-icons">business</i> Instituciones</a></li>
                    <li><a href="/admin/matriculas"><i class="material-icons">assignment</i> Matrículas</a></li>
                    <li><a href="/admin/pagos"><i class="material-icons">payments</i> Pagos</a></li>
                    <li><a href="/admin/reportes"><i class="material-icons">show_chart</i> Reportes</a></li>
                    <li><a href="/admin/configuracion-sistema"><i class="material-icons">settings</i> Configuración</a></li>
                    <li><a href="/admin/seguridad"><i class="material-icons">security</i> Seguridad</a></li>
                    <li><a href="/admin/soporte-admin"><i class="material-icons">forum</i> Soporte</a></li>
                    <li><a href="/admin/auditoria"><i class="material-icons">assignment</i> Auditoría</a></li>
                    <li><a href="/admin/mantenimiento"><i class="material-icons">build</i> Mantenimiento</a></li>
                    <li><a href="/admin/notificaciones"><i class="material-icons">campaign</i> Notificaciones</a></li>
                    <li><a href="/admin/integraciones"><i class="material-icons">power</i> Integraciones</a></li>
                    <li><a href="/admin/backup"><i class="material-icons">backup</i> Backup</a></li>
                </ul>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="dashboard-main">
            <!-- Header -->
            <div class="dashboard-card">
                <h1><i class="material-icons">bar_chart</i> Dashboard Administrativo</h1>
                <p>Bienvenido, <%= user.nombres %> - Gestiona toda la plataforma</p>
                <p>Panel de control general del sistema EduConecta</p>
            </div>

            <!-- System Overview Stats -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon blue"><i class="material-icons">people</i></div>
                    <div class="stat-info">
                        <h3>2,456</h3>
                        <p>Usuarios Totales</p>
                        <div style="font-size: 0.8rem; color: #28a745;">↑ 12% este mes</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon green"><i class="material-icons">menu_book</i></div>
                    <div class="stat-info">
                        <h3>89</h3>
                        <p>Cursos Activos</p>
                        <div style="font-size: 0.8rem; color: #667eea;">↑ 5 nuevos</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon orange"><i class="material-icons">business</i></div>
                    <div class="stat-info">
                        <h3>23</h3>
                        <p>Instituciones</p>
                        <div style="font-size: 0.8rem; color: #28a745;">↑ 2 nuevas</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon red"><i class="material-icons">payments</i></div>
                    <div class="stat-info">
                        <h3>$45,678</h3>
                        <p>Ingresos Mensuales</p>
                        <div style="font-size: 0.8rem; color: #28a745;">↑ 18% vs mes anterior</div>
                    </div>
                </div>
            </div>

            <!-- User Distribution -->
            <div class="dashboard-card">
                <h2><i class="material-icons">people</i> Distribución de Usuarios</h2>
                <div style="display: flex; gap: 2rem;">
                    <div style="flex: 1;">
                        <h3 style="margin-bottom: 1rem;"><i class="material-icons">bar_chart</i> Por Rol</h3>
                        <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px;">
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Estudiantes</span>
                                    <span style="font-weight: bold; color: #667eea;">1,890</span>
                                </div>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 77%;"></div>
                                </div>
                            </div>
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Docentes</span>
                                    <span style="font-weight: bold; color: #667eea;">234</span>
                                </div>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 10%;"></div>
                                </div>
                            </div>
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Administradores</span>
                                    <span style="font-weight: bold; color: #667eea;">12</span>
                                </div>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 0.5%;"></div>
                                </div>
                            </div>
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Coordinadores</span>
                                    <span style="font-weight: bold; color: #667eea;">45</span>
                                </div>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 2%;"></div>
                                </div>
                            </div>
                            <div>
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Soporte Técnico</span>
                                    <span style="font-weight: bold; color: #667eea;">8</span>
                                </div>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 0.3%;"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div style="flex: 1;">
                        <h3 style="margin-bottom: 1rem;"><i class="material-icons">show_chart</i> Estadísticas Clave</h3>
                        <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px;">
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Usuarios Activos Hoy</span>
                                    <span style="font-weight: bold; color: #28a745;">456</span>
                                </div>
                            </div>
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Nuevos Usuarios (Mes)</span>
                                    <span style="font-weight: bold; color: #667eea;">89</span>
                                </div>
                            </div>
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Tasa de Retención</span>
                                    <span style="font-weight: bold; color: #28a745;">87%</span>
                                </div>
                            </div>
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Tiempo Promedio en Plataforma</span>
                                    <span style="font-weight: bold; color: #667eea;">45 min/día</span>
                                </div>
                            </div>
                            <div>
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Usuarios Verificados</span>
                                    <span style="font-weight: bold; color: #28a745;">92%</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Activities -->
            <div class="dashboard-card">
                <h2><i class="material-icons">assignment</i> Actividades Recientes del Sistema</h2>
                <div style="overflow-x: auto;">
                    <table style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="background: #f8f9fa;">
                                <th style="padding: 1rem; text-align: left;">Usuario</th>
                                <th style="padding: 1rem; text-align: left;">Actividad</th>
                                <th style="padding: 1rem; text-align: center;">Módulo</th>
                                <th style="padding: 1rem; text-align: center;">IP</th>
                                <th style="padding: 1rem; text-align: center;">Fecha/Hora</th>
                                <th style="padding: 1rem; text-align: center;">Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr style="border-bottom: 1px solid #f0f0f0;">
                                <td style="padding: 1rem;">
                                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                                        <img src="https://via.placeholder.com/32x32/667eea/ffffff?text=J" alt="Usuario" style="width: 32px; height: 32px; border-radius: 50%;">
                                        <div>
                                            <div style="font-weight: bold;">Juan Pérez</div>
                                            <div style="font-size: 0.8rem; color: #666;">Estudiante</div>
                                        </div>
                                    </div>
                                </td>
                                <td style="padding: 1rem;">
                                    <div>Inscripción a curso "Marketing Digital"</div>
                                </td>
                                <td style="padding: 1rem; text-align: center;">
                                    <span style="background: #667eea; color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.8rem;">Cursos</span>
                                </td>
                                <td style="padding: 1rem; text-align: center;">
                                    <div style="font-size: 0.9rem;">192.168.1.1</div>
                                </td>
                                <td style="padding: 1rem; text-align: center;">
                                    <div style="font-size: 0.9rem;">Hoy, 2:30 PM</div>
                                </td>
                                <td style="padding: 1rem; text-align: center;">
                                    <span style="background: #28a745; color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.8rem;">Exitoso</span>
                                </td>
                            </tr>
                            <tr style="border-bottom: 1px solid #f0f0f0;">
                                <td style="padding: 1rem;">
                                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                                        <img src="https://via.placeholder.com/32x32/28a745/ffffff?text=M" alt="Usuario" style="width: 32px; height: 32px; border-radius: 50%;">
                                        <div>
                                            <div style="font-weight: bold;">María González</div>
                                            <div style="font-size: 0.8rem; color: #666;">Docente</div>
                                        </div>
                                    </div>
                                </td>
                                <td style="padding: 1rem;">
                                    <div>Creación de nueva evaluación</div>
                                </td>
                                <td style="padding: 1rem; text-align: center;">
                                    <span style="background: #28a745; color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.8rem;">Evaluaciones</span>
                                </td>
                                <td style="padding: 1rem; text-align: center;">
                                    <div style="font-size: 0.9rem;">192.168.1.2</div>
                                </td>
                                <td style="padding: 1rem; text-align: center;">
                                    <div style="font-size: 0.9rem;">Hoy, 1:15 PM</div>
                                </td>
                                <td style="padding: 1rem; text-align: center;">
                                    <span style="background: #28a745; color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.8rem;">Exitoso</span>
                                </td>
                            </tr>
                            <tr style="border-bottom: 1px solid #f0f0f0;">
                                <td style="padding: 1rem;">
                                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                                        <img src="https://via.placeholder.com/32x32/dc3545/ffffff?text=A" alt="Usuario" style="width: 32px; height: 32px; border-radius: 50%;">
                                        <div>
                                            <div style="font-weight: bold;">Admin Sistema</div>
                                            <div style="font-size: 0.8rem; color: #666;">Administrador</div>
                                        </div>
                                    </div>
                                </td>
                                <td style="padding: 1rem;">
                                    <div>Configuración de sistema actualizada</div>
                                </td>
                                <td style="padding: 1rem; text-align: center;">
                                    <span style="background: #dc3545; color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.8rem;">Sistema</span>
                                </td>
                                <td style="padding: 1rem; text-align: center;">
                                    <div style="font-size: 0.9rem;">192.168.1.100</div>
                                </td>
                                <td style="padding: 1rem; text-align: center;">
                                    <div style="font-size: 0.9rem;">Hoy, 12:00 PM</div>
                                </td>
                                <td style="padding: 1rem; text-align: center;">
                                    <span style="background: #28a745; color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.8rem;">Exitoso</span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- System Health -->
            <div class="dashboard-card">
                <h2><i class="material-icons">build</i> Estado del Sistema</h2>
                <div class="course-grid">
                    <div class="course-card">
                        <div style="padding: 1.5rem;">
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                                <h3>🖥️ Servidores</h3>
                                <span style="background: #28a745; color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.8rem;">Operativo</span>
                            </div>
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">CPU</span>
                                    <span style="font-weight: bold; color: #28a745;">45%</span>
                                </div>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 45%;"></div>
                                </div>
                            </div>
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Memoria</span>
                                    <span style="font-weight: bold; color: #ffc107;">67%</span>
                                </div>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 67%; background: #ffc107;"></div>
                                </div>
                            </div>
                            <div>
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Almacenamiento</span>
                                    <span style="font-weight: bold; color: #28a745;">34%</span>
                                </div>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 34%;"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="course-card">
                        <div style="padding: 1.5rem;">
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                                <h3>🗄️ Base de Datos</h3>
                                <span style="background: #28a745; color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.8rem;">Sincronizada</span>
                            </div>
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Conexiones Activas</span>
                                    <span style="font-weight: bold; color: #667eea;">23</span>
                                </div>
                            </div>
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Tiempo de Respuesta</span>
                                    <span style="font-weight: bold; color: #28a745;">12 ms</span>
                                </div>
                            </div>
                            <div>
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Último Backup</span>
                                    <span style="font-weight: bold; color: #28a745;">Hace 2 horas</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="course-card">
                        <div style="padding: 1.5rem;">
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                                <h3><i class="material-icons">language</i> Servicios Web</h3>
                                <span style="background: #28a745; color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.8rem;">Online</span>
                            </div>
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">API Server</span>
                                    <span style="font-weight: bold; color: #28a745;">🟢 Activo</span>
                                </div>
                            </div>
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Web Server</span>
                                    <span style="font-weight: bold; color: #28a745;">🟢 Activo</span>
                                </div>
                            </div>
                            <div>
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Email Service</span>
                                    <span style="font-weight: bold; color: #28a745;">🟢 Activo</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Financial Overview -->
            <div class="dashboard-card">
                <h2><i class="material-icons">payments</i> Resumen Financiero</h2>
                <div style="display: flex; gap: 2rem;">
                    <div style="flex: 1;">
                        <h3 style="margin-bottom: 1rem;"><i class="material-icons">show_chart</i> Ingresos Mensuales</h3>
                        <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px;">
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Enero</span>
                                    <span style="font-weight: bold; color: #667eea;">$38,450</span>
                                </div>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 84%;"></div>
                                </div>
                            </div>
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Febrero</span>
                                    <span style="font-weight: bold; color: #667eea;">$42,890</span>
                                </div>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 94%;"></div>
                                </div>
                            </div>
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Marzo</span>
                                    <span style="font-weight: bold; color: #667eea;">$45,678</span>
                                </div>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 100%;"></div>
                                </div>
                            </div>
                            <div>
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Proyección Abril</span>
                                    <span style="font-weight: bold; color: #28a745;">$48,500</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div style="flex: 1;">
                        <h3 style="margin-bottom: 1rem;"><i class="material-icons">lightbulb</i> Métricas Financieras</h3>
                        <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px;">
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Ingreso Promedio por Usuario</span>
                                    <span style="font-weight: bold; color: #28a745;">$18.60</span>
                                </div>
                            </div>
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Tasa de Conversión</span>
                                    <span style="font-weight: bold; color: #667eea;">15.2%</span>
                                </div>
                            </div>
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Valor de Vida del Cliente</span>
                                    <span style="font-weight: bold; color: #667eea;">$245.80</span>
                                </div>
                            </div>
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Ingresos Recurrentes</span>
                                    <span style="font-weight: bold; color: #28a745;">$12,340/mes</span>
                                </div>
                            </div>
                            <div>
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Proyección Anual</span>
                                    <span style="font-weight: bold; color: #28a745;">$548,000</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="dashboard-card">
                <h2>⚡ Acciones Rápidas</h2>
                <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
