                        </div>
                    </div>
                </div>
            </div>

            <!-- Authentication Settings -->
            <div class="dashboard-card">
                <h2>🔐 Configuración de Autenticación</h2>
                <form>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Política de Contraseñas</label>
                            <select class="form-control">
                                <option value="standard" selected>Estándar (8+ caracteres)</option>
                                <option value="strong">Fuerte (12+ caracteres, símbolos)</option>
                                <option value="complex">Compleja (16+ caracteres, mayúsculas, números, símbolos)</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Expiración de Contraseñas</label>
                            <select class="form-control">
                                <option value="never">Nunca</option>
                                <option value="30">30 días</option>
                                <option value="60">60 días</option>
                                <option value="90" selected>90 días</option>
                                <option value="180">180 días</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Intentos de Login Permitidos</label>
                            <input type="number" class="form-control" value="5" min="3" max="10">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Tiempo de Bloqueo (minutos)</label>
                            <input type="number" class="form-control" value="15" min="5" max="60">
                        </div>
                    </div>

                    <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px; margin-bottom: 2rem;">
                        <h3 style="margin-bottom: 1rem;"><i class="material-icons">build</i> Opciones de Seguridad</h3>
                        <label style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">Autenticación de Dos Factores</div>
                                <div style="font-size: 0.9rem; color: #666;">Requerir 2FA para todos los usuarios</div>
                            </div>
                            <input type="checkbox" style="width: 20px; height: 20px;">
                        </label>
                        <label style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">Login con Redes Sociales</div>
                                <div style="font-size: 0.9rem; color: #666;">Permitir login con Google, Facebook, etc.</div>
                            </div>
                            <input type="checkbox" checked style="width: 20px; height: 20px;">
                        </label>
                        <label style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">Verificación de Email Obligatoria</div>
                                <div style="font-size: 0.9rem; color: #666;">Exigir verificación para activar cuenta</div>
                            </div>
                            <input type="checkbox" checked style="width: 20px; height: 20px;">
                        </label>
                        <label style="display: flex; align-items: center; justify-content: space-between;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">Sesiones Simultáneas</div>
                                <div style="font-size: 0.9rem; color: #666;">Permitir múltiples sesiones por usuario</div>
                            </div>
                            <input type="checkbox" checked style="width: 20px; height: 20px;">
                        </label>
                    </div>

                    <div style="text-align: right;">
                        <button type="button" class="btn btn-outline" style="margin-right: 1rem;">Restablecer</button>
                        <button type="submit" class="btn btn-primary">Guardar Cambios</button>
                    </div>
                </form>
            </div>

