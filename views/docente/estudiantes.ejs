                                    <option value="at-risk">Estudiantes en riesgo</option>
                                    <option value="course">Por curso específico</option>
                                </select>
                            </div>
                            <div style="margin-bottom: 1rem;">
                                <label class="form-label">Asunto</label>
                                <input type="text" class="form-control" placeholder="Asunto del mensaje">
                            </div>
                            <div style="margin-bottom: 1rem;">
                                <label class="form-label">Mensaje</label>
                                <textarea class="form-control" rows="4" placeholder="Escribe tu mensaje aquí..."></textarea>
                            </div>
                            <button class="btn btn-primary">Enviar Mensaje</button>
                        </div>
                    </div>
                    
                    <div style="flex: 1;">
                        <h3 style="margin-bottom: 1rem;"><i class="material-icons">bar_chart</i> Estadísticas de Comunicación</h3>
                        <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px;">
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Mensajes enviados esta semana</span>
                                    <span style="font-weight: bold; color: #667eea;">12</span>
                                </div>
                            </div>
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Tasa de respuesta</span>
                                    <span style="font-weight: bold; color: #28a745;">78%</span>
                                </div>
                            </div>
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Estudiantes contactados</span>
                                    <span style="font-weight: bold; color: #764ba2;">45</span>
                                </div>
                            </div>
                            <div>
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-size: 0.9rem;">Próximo recordatorio programado</span>
                                    <span style="font-weight: bold; color: #ffc107;">Mañana, 10:00 AM</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Export Data -->
            <div class="dashboard-card">
                <h2>📥 Exportar Datos de Estudiantes</h2>
                <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
                    <button class="btn btn-outline"><i class="material-icons">bar_chart</i> Exportar CSV (Todos)</button>
                    <button class="btn btn-outline"><i class="material-icons">show_chart</i> Exportar Reporte de Progreso</button>
                    <button class="btn btn-outline"><i class="material-icons">assignment</i> Exportar Lista de Asistencia</button>
                    <button class="btn btn-outline"><i class="material-icons">email</i> Exportar Contactos</button>
                </div>
            </div>
        </main>
    </div>

    <!-- Footer -->
    <footer class="dashboard-footer">
        <div class="container">
            <p>&copy; 2024 EduConecta. Panel Docente</p>
        </div>
    </footer>
</body>
