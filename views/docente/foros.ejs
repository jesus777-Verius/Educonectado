            <!-- Create Forum Form -->
            <div class="dashboard-card">
                <h2><i class="material-icons">add</i> Crear Nuevo Foro</h2>
                <form>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Nombre del Foro *</label>
                            <input type="text" class="form-control" placeholder="Ej: Ayuda con JavaScript" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Curso *</label>
                            <select class="form-control" required>
                                <option value="">Selecciona un curso</option>
                                <option value="marketing">Marketing Digital</option>
                                <option value="programming">Programación Web</option>
                                <option value="business">Gestión Empresarial</option>
                                <option value="design">Diseño Gráfico</option>
                                <option value="english">Inglés Conversacional</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Descripción *</label>
                        <textarea class="form-control" rows="3" placeholder="Describe el propósito y las reglas de este foro..." required></textarea>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Tipo de Foro</label>
                            <select class="form-control">
                                <option value="general">Discusión General</option>
                                <option value="help">Ayuda y Soporte</option>
                                <option value="projects">Proyectos Compartidos</option>
                                <option value="announcements">Anuncios</option>
                                <option value="resources">Recursos Compartidos</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Visibilidad</label>
                            <select class="form-control">
                                <option value="public">Público (todos los estudiantes)</option>
                                <option value="private">Privado (solo inscritos)</option>
                                <option value="moderated">Moderado (requiere aprobación)</option>
                            </select>
                        </div>
                    </div>

                    <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px; margin-bottom: 2rem;">
                        <h3 style="margin-bottom: 1rem;"><i class="material-icons">settings</i> Configuración del Foro</h3>
                        <label style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">Permitir que los estudiantes creen temas</div>
                                <div style="font-size: 0.9rem; color: #666;">Los estudiantes pueden iniciar nuevas discusiones</div>
                            </div>
                            <input type="checkbox" checked style="width: 20px; height: 20px;">
                        </label>
                        <label style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">Moderación requerida</div>
                                <div style="font-size: 0.9rem; color: #666;">Las publicaciones necesitan aprobación</div>
                            </div>
                            <input type="checkbox" style="width: 20px; height: 20px;">
                        </label>
                        <label style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">Permitir archivos adjuntos</div>
                                <div style="font-size: 0.9rem; color: #666;">Los estudiantes pueden subir archivos</div>
                            </div>
                            <input type="checkbox" checked style="width: 20px; height: 20px;">
                        </label>
                        <label style="display: flex; align-items: center; justify-content: space-between;">
                            <div>
                                <div style="font-weight: bold; margin-bottom: 0.25rem;">Notificaciones automáticas</div>
                                <div style="font-size: 0.9rem; color: #666;">Notificar nuevas publicaciones</div>
                            </div>
                            <input type="checkbox" checked style="width: 20px; height: 20px;">
                        </label>
                    </div>

                    <div style="text-align: right;">
                        <button type="button" class="btn btn-outline" style="margin-right: 1rem;">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Crear Foro</button>
                    </div>
                </form>
            </div>

            <!-- Moderation Queue -->
            <div class="dashboard-card">
                <h2><i class="material-icons">warning</i> Cola de Moderación</h2>
                <div class="course-grid">
                    <div class="course-card" style="border: 2px solid #dc3545;">
                        <div style="padding: 1.5rem;">
                            <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 1rem;">
                                <div>
                                    <h4 style="margin-bottom: 0.5rem;">Comentario inapropiado</h4>
                                    <p style="color: #666; font-size: 0.9rem;">Reportado por: Luisa Fernández</p>
                                </div>
                                <span style="background: #dc3545; color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.8rem;">Alta Prioridad</span>
                            </div>
                            <div style="background: #f8f9fa; padding: 1rem; border-radius: 8px; margin-bottom: 1rem;">
                                <p style="margin: 0;">"Este curso es una pérdida de tiempo y el instructor no sabe nada..."</p>
                            </div>
                            <div style="margin-bottom: 1rem;">
                                <div style="font-size: 0.8rem; color: #666;">
                                    <span><i class="material-icons">menu_book</i> Foro: Diseño Gráfico - Proyectos</span>
                                    <span style="margin-left: 1rem;">👤 Autor: Roberto Silva</span>
                                    <span style="margin-left: 1rem;"><i class="material-icons">calendar_today</i> Hace 1 hora</span>
                                </div>
                            </div>
                            <div style="display: flex; gap: 0.5rem;">
                                <button class="btn btn-outline" style="flex: 1; border-color: #dc3545; color: #dc3545;">Eliminar</button>
                                <button class="btn btn-outline" style="flex: 1;">Advertir Usuario</button>
                                <button class="btn btn-primary" style="flex: 1;">Aprobar</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Forum Analytics -->
            <div class="dashboard-card">
                <h2><i class="material-icons">bar_chart</i> Análisis de Foros</h2>
                <div style="display: flex; gap: 2rem;">
                    <div style="flex: 1;">
