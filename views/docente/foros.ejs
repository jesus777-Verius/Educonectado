                                </td>
                                <td style="padding: 1rem; text-align: center;">
                                    <div style="display: flex; align-items: center; gap: 0.5rem; justify-content: center;">
                                        <img src="https://via.placeholder.com/24x24/764ba2/ffffff?text=A" alt="Usuario" style="width: 24px; height: 24px; border-radius: 50%;">
