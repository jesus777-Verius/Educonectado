<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Marketing Digital Completo - EduConecta</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200">
    <style>
        .modal {
            display: none;
            position: fixed;
            z-index: 10000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.5);
            backdrop-filter: blur(5px);
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .modal.active {
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 1;
        }

        .modal-content {
            background: white;
            border-radius: 20px;
            padding: 3rem;
            max-width: 500px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
            position: relative;
            box-shadow: 0 25px 50px rgba(0,0,0,0.3);
            animation: modalSlideIn 0.3s ease-out;
        }
        @keyframes modalSlideIn {
            from {
                opacity: 0;
                transform: translateY(-50px) scale(0.9);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }
        .modal-close {
            position: absolute;
            top: 1.5rem;
            right: 1.5rem;
            background: #f8f9fa;
            border: none;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        .modal-close:hover {
            background: #e9ecef;
            transform: rotate(90deg);
        }
        .form-group {
            margin-bottom: 1.5rem;
        }
        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 600;
            color: #333;
        }
        .form-group input,
        .form-group password {
            width: 100%;
            padding: 1rem;
            border: 2px solid #e9ecef;
            border-radius: 10px;
            font-size: 1rem;
            transition: all 0.3s ease;
        }
        .form-group input:focus,
        .form-group password:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }
        .btn {
            padding: 1rem 2rem;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
        }
        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(102, 126, 234, 0.3);
        }
        .btn-outline {
            border: 2px solid #667eea;
            color: #667eea;
            background: transparent;
        }
        .btn-outline:hover {
            background: #667eea;
            color: white;
        }
    </style>
</head>
<body>
    <!-- Header -->
    <header class="header">
        <nav class="container nav">
            <a href="/" class="logo"><i class="material-icons">menu_book</i> EduConecta</a>
            <ul class="nav-links">
                <li><a href="/">Inicio</a></li>
                <li><a href="/catalogo">Catálogo</a></li>
                <li><a href="/precios">Precios</a></li>
                <li><a href="/blog">Blog</a></li>
                <li><a href="/quienes-somos">Nosotros</a></li>
                <li><a href="/contacto">Contacto</a></li>
                <li><a href="#" class="btn btn-outline" onclick="openModal('loginModal')">Iniciar Sesión</a></li>
                <li><a href="#" class="btn btn-primary" onclick="openModal('registerModal')">Crear Cuenta</a></li>
            </ul>
        </nav>
    </header>

    <!-- Course Header -->
    <section style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 3rem 0;">
        <div class="container">
            <div class="grid grid-2" style="align-items: center;">
                <div>
                    <div style="margin-bottom: 1rem;">
                        <span style="background: rgba(255,255,255,0.2); padding: 0.5rem 1rem; border-radius: 20px;"><%= course.category %></span>
                        <span style="margin-left: 1rem;"><i class="material-icons">star</i> <%= course.rating %> (<%= course.reviews %> reseñas)</span>
                    </div>
                    <h1 style="font-size: 2.5rem; margin-bottom: 1rem;"><%= course.title %></h1>
                    <p style="font-size: 1.2rem; margin-bottom: 2rem; opacity: 0.9;"><%= course.description %> con enfoque práctico para el mercado venezolano.</p>
                    <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
                        <div>
                            <strong>Instructor:</strong> Carlos Méndez
                        </div>
                        <div>
                            <strong>Duración:</strong> <%= course.hours %> horas
                        </div>
                        <div>
                            <strong>Lecciones:</strong> <%= course.lessons %>
                        </div>
                        <div>
                            <strong>Nivel:</strong> <%= course.level %>
                        </div>
                    </div>
                </div>
                <div>
                    <img src="<%= course.image %>" alt="<%= course.title %>" style="width: 100%; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.2);">
                </div>
            </div>
        </div>
    </section>

    <!-- Course Content -->
    <section class="container mb-3">
        <div class="grid grid-3" style="gap: 2rem;">
            <!-- Main Content -->
            <div style="grid-column: span 2;">
                <!-- Description -->
                <div class="card mb-3">
                    <h2 class="card-title">Descripción del Curso</h2>
                    <p>Este curso completo de marketing digital te enseñará las estrategias más efectivas para promover productos y servicios online. Aprenderás desde los conceptos básicos hasta técnicas avanzadas de SEO, marketing en redes sociales, email marketing y publicidad pagada.</p>
                    <p>El curso está diseñado específicamente para el mercado venezolano, considerando las particularidades del entorno digital local y las plataformas más utilizadas en la región.</p>
                    <h3 style="margin-top: 2rem; margin-bottom: 1rem;">¿Qué aprenderás?</h3>
                    <ul style="line-height: 2;">
                        <li><i class="material-icons">check_circle</i> Fundamentos del marketing digital y su aplicación en Venezuela</li>
                        <li><i class="material-icons">check_circle</i> Estrategias de SEO para posicionamiento en buscadores</li>
                        <li><i class="material-icons">check_circle</i> Marketing en redes sociales (Instagram, Facebook, TikTok)</li>
                        <li><i class="material-icons">check_circle</i> Creación de contenido efectivo y viral</li>
                        <li><i class="material-icons">check_circle</i> Email marketing y automatización</li>
                        <li><i class="material-icons">check_circle</i> Publicidad en Google Ads y Facebook Ads</li>
                        <li><i class="material-icons">check_circle</i> Análisis de métricas y ROI</li>
                        <li><i class="material-icons">check_circle</i> Creación de un plan de marketing integral</li>
                    </ul>
                </div>

                <!-- Curriculum -->
                <div class="card mb-3">
                    <h2 class="card-title">Temario del Curso</h2>
                    <div style="border: 1px solid #e0e0e0; border-radius: 8px; overflow: hidden;">
                        <!-- Module 1 -->
                        <div style="border-bottom: 1px solid #e0e0e0;">
                            <div style="background: #f8f9fa; padding: 1rem; cursor: pointer;">
                                <h4 style="margin: 0; color: #667eea;">Módulo 1: Fundamentos del Marketing Digital</h4>
                                <small style="color: #666;">4 lecciones • 1.5 horas</small>
                            </div>
                            <div style="padding: 1rem;">
                                <div style="padding: 0.5rem 0; border-bottom: 1px solid #f0f0f0;">
                                    <span style="margin-right: 1rem;"><i class="material-icons">videocam</i></span>
                                    <span>1.1 Introducción al Marketing Digital</span>
                                    <span style="float: right; color: #666;">15 min</span>
                                </div>
                                <div style="padding: 0.5rem 0; border-bottom: 1px solid #f0f0f0;">
                                    <span style="margin-right: 1rem;"><i class="material-icons">videocam</i></span>
                                    <span>1.2 El Entorno Digital en Venezuela</span>
                                    <span style="float: right; color: #666;">20 min</span>
                                </div>
                                <div style="padding: 0.5rem 0; border-bottom: 1px solid #f0f0f0;">
                                    <span style="margin-right: 1rem;"><i class="material-icons">description</i></span>
                                    <span>1.3 Conceptos Clave y Terminología</span>
                                    <span style="float: right; color: #666;">25 min</span>
                                </div>
                                <div style="padding: 0.5rem 0;">
                                    <span style="margin-right: 1rem;"><i class="material-icons">edit</i></span>
                                    <span>1.4 Quiz: Fundamentos</span>
                                    <span style="float: right; color: #666;">10 preguntas</span>
                                </div>
                            </div>
                        </div>

                        <!-- Module 2 -->
                        <div style="border-bottom: 1px solid #e0e0e0;">
                            <div style="background: #f8f9fa; padding: 1rem; cursor: pointer;">
                                <h4 style="margin: 0; color: #667eea;">Módulo 2: SEO y Posicionamiento</h4>
                                <small style="color: #666;">3 lecciones • 2 horas</small>
                            </div>
                            <div style="padding: 1rem;">
                                <div style="padding: 0.5rem 0; border-bottom: 1px solid #f0f0f0;">
                                    <span style="margin-right: 1rem;"><i class="material-icons">videocam</i></span>
                                    <span>2.1 SEO On-Page Fundamentals</span>
                                    <span style="float: right; color: #666;">45 min</span>
                                </div>
                                <div style="padding: 0.5rem 0; border-bottom: 1px solid #f0f0f0;">
                                    <span style="margin-right: 1rem;"><i class="material-icons">videocam</i></span>
                                    <span>2.2 SEO Off-Page y Link Building</span>
                                    <span style="float: right; color: #666;">40 min</span>
                                </div>
                                <div style="padding: 0.5rem 0;">
                                    <span style="margin-right: 1rem;"><i class="material-icons">edit</i></span>
                                    <span>2.3 Práctica: Optimización de Sitio Web</span>
                                    <span style="float: right; color: #666;">35 min</span>
                                </div>
                            </div>
                        </div>

                        <!-- Module 3 -->
                        <div style="border-bottom: 1px solid #e0e0e0;">
                            <div style="background: #f8f9fa; padding: 1rem; cursor: pointer;">
                                <h4 style="margin: 0; color: #667eea;">Módulo 3: Redes Sociales</h4>
                                <small style="color: #666;">4 lecciones • 2.5 horas</small>
                            </div>
                        </div>

                        <!-- Module 4 -->
                        <div>
                            <div style="background: #f8f9fa; padding: 1rem; cursor: pointer;">
                                <h4 style="margin: 0; color: #667eea;">Módulo 4: Publicidad Digital</h4>
                                <small style="color: #666;">3 lecciones • 2 horas</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Instructor -->
                <div class="card mb-3">
                    <h2 class="card-title">Sobre el Instructor</h2>
                    <div style="display: flex; gap: 1rem; align-items: start;">
                        <img src="https://via.placeholder.com/100x100/667eea/ffffff?text=CM" alt="Instructor" style="width: 100px; height: 100px; border-radius: 50%;">
                        <div>
                            <h3>Carlos Méndez</h3>
                            <p style="color: #666;">Especialista en Marketing Digital con más de 10 años de experiencia. Certificado en Google Analytics y Facebook Blueprint. Ha trabajado con marcas importantes en Venezuela y Latinoamérica.</p>
                            <div style="margin-top: 1rem;">
                                <span style="margin-right: 1rem;"><i class="material-icons">school</i> <strong>15,000+</strong> estudiantes</span>
                                <span style="margin-right: 1rem;"><i class="material-icons">star</i> <strong>4.9</strong> rating promedio</span>
                                <span><i class="material-icons">menu_book</i> <strong>8</strong> cursos</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Reviews -->
                <div class="card">
                    <h2 class="card-title">Reseñas de Estudiantes</h2>
                    <div class="grid grid-2">
                        <div style="border: 1px solid #e0e0e0; padding: 1rem; border-radius: 8px;">
                            <div style="margin-bottom: 0.5rem;">
                                <span style="color: #ffc107;"><i class="material-icons">star</i><i class="material-icons">star</i><i class="material-icons">star</i><i class="material-icons">star</i><i class="material-icons">star</i></span>
                                <small style="float: right;">Hace 2 días</small>
                            </div>
                            <p style="font-size: 0.9rem; margin-bottom: 0.5rem;">"Excelente curso, muy práctico y aplicable al mercado venezolano. El instructor explica muy claro."</p>
                            <strong>- María González</strong>
                        </div>
                        <div style="border: 1px solid #e0e0e0; padding: 1rem; border-radius: 8px;">
                            <div style="margin-bottom: 0.5rem;">
                                <span style="color: #ffc107;"><i class="material-icons">star</i><i class="material-icons">star</i><i class="material-icons">star</i><i class="material-icons">star</i><i class="material-icons">star</i></span>
                                <small style="float: right;">Hace 1 semana</small>
                            </div>
                            <p style="font-size: 0.9rem; margin-bottom: 0.5rem;">"Aprendí mucho sobre SEO y ya estoy aplicando las técnicas en mi negocio. ¡Recomendado!"</p>
                            <strong>- Luis Pérez</strong>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div>
                <!-- Purchase Card -->
                <div class="card" style="position: sticky; top: 20px;">
                    <div style="text-align: center; margin-bottom: 1.5rem;">
                        <% if (course.price === 0) { %>
                            <div style="font-size: 2rem; color: #28a745; font-weight: bold;">GRATIS</div>
                            <div style="text-decoration: line-through; color: #999;">$<%= course.originalPrice %></div>
                            <div style="color: #28a745; font-weight: bold;">100% OFF - Siempre gratis</div>
                        <% } else { %>
                            <div style="font-size: 2rem; color: #667eea; font-weight: bold;">$<%= course.price %></div>
                            <div style="text-decoration: line-through; color: #999;">$<%= course.originalPrice %></div>
                            <div style="color: #28a745; font-weight: bold;"><%= course.discount %>% OFF - Tiempo limitado</div>
                        <% } %>
                    </div>

                    <button class="btn btn-primary" style="width: 100%; margin-bottom: 1rem;" onclick="startPurchase()">Comprar Ahora</button>
                    <button class="btn btn-outline" style="width: 100%; margin-bottom: 1rem;" onclick="addToCart()">Añadir al Carrito</button>
                    <button class="btn btn-secondary" style="width: 100%; display: block; text-align: center;" onclick="openModal('loginModal')">Iniciar Sesión para Comprar</button>

                    <hr style="margin: 1.5rem 0;">

                    <h4 style="margin-bottom: 1rem;">Este curso incluye:</h4>
                    <ul style="list-style: none; padding: 0;">
                        <li style="margin-bottom: 0.5rem;">✓ <%= course.lessons %> lecciones en video</li>
                        <li style="margin-bottom: 0.5rem;">✓ <%= course.hours %> horas de contenido</li>
                        <li style="margin-bottom: 0.5rem;">✓ Recursos descargables</li>
                        <li style="margin-bottom: 0.5rem;">✓ Certificado de finalización</li>
                        <li style="margin-bottom: 0.5rem;">✓ Acceso de por vida</li>
                        <li style="margin-bottom: 0.5rem;">✓ Soporte del instructor</li>
                        <li style="margin-bottom: 0.5rem;">✓ Acceso móvil</li>
                        <li>✓ Garantía de reembolso 30 días</li>
                    </ul>

                    <hr style="margin: 1.5rem 0;">

                    <div style="text-align: center;">
                        <small style="color: #666;"><i class="material-icons">security</i> Compra 100% segura</small>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Related Courses -->
    <section class="container mb-3">
        <h2 class="text-center mb-2">Cursos Relacionados</h2>
        <div class="grid grid-3">
            <div class="card">
                <img src="https://via.placeholder.com/300x200/764ba2/ffffff?text=SEO+Avanzado" alt="Curso" style="width: 100%; height: 150px; object-fit: cover; border-radius: 8px 8px 0 0;">
                <div style="padding: 1rem;">
                    <h4 style="margin-bottom: 0.5rem;">SEO Avanzado</h4>
                    <p style="font-size: 0.9rem; color: #666;">Técnicas avanzadas de posicionamiento</p>
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 1rem;">
                        <span style="color: #667eea; font-weight: bold;">$39.99</span>
                        <a href="/curso/2" class="btn btn-primary" style="padding: 0.5rem 1rem; font-size: 0.9rem;">Ver</a>
                    </div>
                </div>
            </div>
            <div class="card">
                <img src="https://via.placeholder.com/300x200/667eea/ffffff?text=Redes+Sociales" alt="Curso" style="width: 100%; height: 150px; object-fit: cover; border-radius: 8px 8px 0 0;">
                <div style="padding: 1rem;">
                    <h4 style="margin-bottom: 0.5rem;">Marketing en Redes</h4>
                    <p style="font-size: 0.9rem; color: #666;">Estrategias para redes sociales</p>
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 1rem;">
                        <span style="color: #667eea; font-weight: bold;">$24.99</span>
                        <a href="/curso/3" class="btn btn-primary" style="padding: 0.5rem 1rem; font-size: 0.9rem;">Ver</a>
                    </div>
                </div>
            </div>
            <div class="card">
                <img src="https://via.placeholder.com/300x200/764ba2/ffffff?text=Email+Marketing" alt="Curso" style="width: 100%; height: 150px; object-fit: cover; border-radius: 8px 8px 0 0;">
                <div style="padding: 1rem;">
                    <h4 style="margin-bottom: 0.5rem;">Email Marketing</h4>
                    <p style="font-size: 0.9rem; color: #666;">Automatización y campañas efectivas</p>
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 1rem;">
                        <span style="color: #667eea; font-weight: bold;">$19.99</span>
                        <a href="/curso/4" class="btn btn-primary" style="padding: 0.5rem 1rem; font-size: 0.9rem;">Ver</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Login Modal -->
    <div id="loginModal" class="modal">
        <div class="modal-content">
            <button class="modal-close" onclick="closeModal('loginModal')">
                <span class="material-symbols-outlined">close</span>
            </button>
            <div style="text-align: center; margin-bottom: 2rem;">
                <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 0.75rem 1.5rem; border-radius: 50px; display: inline-block; font-weight: 600; margin-bottom: 1rem;">
                    <span class="material-symbols-outlined" style="font-size: 1.2rem; vertical-align: middle; margin-right: 0.5rem;">login</span>
                    Iniciar Sesión
                </div>
                <h2 style="color: #333; font-size: 1.8rem; margin-bottom: 0.5rem; font-weight: bold;">Bienvenido de Nuevo</h2>
                <p style="color: #666; font-size: 1rem;">Ingresa tus credenciales para acceder a tu cuenta</p>
            </div>
            <form id="loginForm">
                <div class="form-group">
                    <label for="loginEmail">Correo Electrónico</label>
                    <div style="position: relative;">
                        <input type="email" id="loginEmail" name="email" required placeholder="tu@email.com" style="padding: 1rem 1rem 1rem 3rem;">
                        <div style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: #667eea;">
                            <span class="material-symbols-outlined">email</span>
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label for="loginPassword">Contraseña</label>
                    <div style="position: relative;">
                        <input type="password" id="loginPassword" name="password" required placeholder="••••••••" style="padding: 1rem 1rem 1rem 3rem;">
                        <div style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: #667eea;">
                            <span class="material-symbols-outlined">lock</span>
                        </div>
                    </div>
                </div>
                <div class="form-group" style="display: flex; justify-content: space-between; align-items: center;">
                    <label style="display: flex; align-items: center;">
                        <input type="checkbox" name="remember" style="margin-right: 0.5rem;">
                        <span style="color: #666; font-size: 0.9rem;">Recordarme</span>
                    </label>
                    <a href="#" style="color: #667eea; text-decoration: none; font-size: 0.9rem;">¿Olvidaste tu contraseña?</a>
                </div>
                <button type="submit" class="btn btn-primary" style="width: 100%; margin-bottom: 1rem;">
                    <span class="material-symbols-outlined" style="font-size: 1.2rem; vertical-align: middle; margin-right: 0.5rem;">login</span>
                    Iniciar Sesión
                </button>
                <div style="text-align: center; padding-top: 1rem; border-top: 1px solid #e9ecef;">
                    <p style="color: #666; font-size: 0.9rem; margin-bottom: 0.5rem;">¿No tienes una cuenta?</p>
                    <a href="#" onclick="switchToRegister()" style="color: #667eea; text-decoration: none; font-weight: 600;">Regístrate gratis</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Register Modal -->
    <div id="registerModal" class="modal">
        <div class="modal-content">
            <button class="modal-close" onclick="closeModal('registerModal')">
                <span class="material-symbols-outlined">close</span>
            </button>
            <div style="text-align: center; margin-bottom: 2rem;">
                <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 0.75rem 1.5rem; border-radius: 50px; display: inline-block; font-weight: 600; margin-bottom: 1rem;">
                    <span class="material-symbols-outlined" style="font-size: 1.2rem; vertical-align: middle; margin-right: 0.5rem;">person_add</span>
                    Crear Cuenta
                </div>
                <h2 style="color: #333; font-size: 1.8rem; margin-bottom: 0.5rem; font-weight: bold;">Únete a EduConecta</h2>
                <p style="color: #666; font-size: 1rem;">Comienza tu journey educativo hoy mismo</p>
            </div>
            <form id="registerForm">
                <div class="form-group">
                    <label for="registerName">Nombre Completo</label>
                    <div style="position: relative;">
                        <input type="text" id="registerName" name="name" required placeholder="Juan Pérez" style="padding: 1rem 1rem 1rem 3rem;">
                        <div style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: #667eea;">
                            <span class="material-symbols-outlined">person</span>
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label for="registerEmail">Correo Electrónico</label>
                    <div style="position: relative;">
                        <input type="email" id="registerEmail" name="email" required placeholder="tu@email.com" style="padding: 1rem 1rem 1rem 3rem;">
                        <div style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: #667eea;">
                            <span class="material-symbols-outlined">email</span>
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label for="registerPassword">Contraseña</label>
                    <div style="position: relative;">
                        <input type="password" id="registerPassword" name="password" required placeholder="••••••••" style="padding: 1rem 1rem 1rem 3rem;">
                        <div style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: #667eea;">
                            <span class="material-symbols-outlined">lock</span>
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label for="confirmPassword">Confirmar Contraseña</label>
                    <div style="position: relative;">
                        <input type="password" id="confirmPassword" name="confirmPassword" required placeholder="••••••••" style="padding: 1rem 1rem 1rem 3rem;">
                        <div style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: #667eea;">
                            <span class="material-symbols-outlined">lock</span>
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label style="display: flex; align-items: center; cursor: pointer;">
                        <input type="checkbox" name="terms" required style="margin-right: 0.5rem;">
                        <span style="color: #666; font-size: 0.9rem;">Acepto los términos y condiciones</span>
                    </label>
                </div>
                <button type="submit" class="btn btn-primary" style="width: 100%; margin-bottom: 1rem;">
                    <span class="material-symbols-outlined" style="font-size: 1.2rem; vertical-align: middle; margin-right: 0.5rem;">person_add</span>
                    Crear Cuenta
                </button>
                <div style="text-align: center; padding-top: 1rem; border-top: 1px solid #e9ecef;">
                    <p style="color: #666; font-size: 0.9rem; margin-bottom: 0.5rem;">¿Ya tienes una cuenta?</p>
                    <a href="#" onclick="switchToLogin()" style="color: #667eea; text-decoration: none; font-weight: 600;">Inicia sesión</a>
                </div>
            </form>
        </div>
    </div>

    <!-- JavaScript -->
    <script>
        function openModal(modalId) {
            document.getElementById(modalId).classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeModal(modalId) {
            document.getElementById(modalId).classList.remove('active');
            document.body.style.overflow = 'auto';
        }

        function switchToRegister() {
            closeModal('loginModal');
            setTimeout(() => openModal('registerModal'), 300);
        }

        function switchToLogin() {
            closeModal('registerModal');
            setTimeout(() => openModal('loginModal'), 300);
        }

        // Close modal when clicking outside
        document.addEventListener('click', function(event) {
            if (event.target.classList.contains('modal')) {
                event.target.classList.remove('active');
                document.body.style.overflow = 'auto';
            }
        });

        // Close modal with Escape key
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                const modals = document.querySelectorAll('.modal.active');
                modals.forEach(modal => {
                    modal.classList.remove('active');
                    document.body.style.overflow = 'auto';
                });
            }
        });

        // Form submissions
        document.getElementById('loginForm').addEventListener('submit', function(e) {
            e.preventDefault();
            // Handle login logic here
            console.log('Login submitted');
            closeModal('loginModal');
        });

        document.getElementById('registerForm').addEventListener('submit', function(e) {
            e.preventDefault();
            // Handle registration logic here
            console.log('Register submitted');
            closeModal('registerModal');
        });

        // Purchase functionality
        let cart = [];
        let purchaseCount = 0;

        function startPurchase() {
            const course = {
                id: '<%= course.id %>',
                title: '<%= course.title %>',
                price: '<%= course.price %>',
                originalPrice: '<%= course.originalPrice %>',
                discount: '<%= course.discount %>',
                image: '<%= course.image %>'
            };
            
            // Show purchase modal
            showPurchaseModal(course);
        }

        function addToCart() {
            const course = {
                id: '<%= course.id %>',
                title: '<%= course.title %>',
                price: '<%= course.price %>',
                originalPrice: '<%= course.originalPrice %>',
                discount: '<%= course.discount %>',
                image: '<%= course.image %>'
            };
            
            // Check if course already in cart
            const existingCourse = cart.find(item => item.id === course.id);
            if (existingCourse) {
                showNotification('Este curso ya está en tu carrito', 'warning');
                return;
            }
            
            cart.push(course);
            updateCartCount();
            showNotification('Curso añadido al carrito exitosamente', 'success');
            updateCartButton();
        }

        function showPurchaseModal(course) {
            const modalHtml = `
                <div id="purchaseModal" class="modal active">
                    <div class="modal-content" style="max-width: 600px;">
                        <button class="modal-close" onclick="closePurchaseModal()">
                            <span class="material-symbols-outlined">close</span>
                        </button>
                        <div style="text-align: center; margin-bottom: 2rem;">
                            <div style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%); color: white; padding: 0.75rem 1.5rem; border-radius: 50px; display: inline-block; font-weight: 600; margin-bottom: 1rem;">
                                <span class="material-symbols-outlined" style="font-size: 1.2rem; vertical-align: middle; margin-right: 0.5rem;">shopping_cart</span>
                                Procesar Compra
                            </div>
                            <h2 style="color: #333; font-size: 1.8rem; margin-bottom: 0.5rem; font-weight: bold;">Confirmar Pedido</h2>
                            <p style="color: #666; font-size: 1rem;">Revisa los detalles de tu compra</p>
                        </div>
                        
                        <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 12px; margin-bottom: 2rem;">
                            <div style="display: flex; gap: 1rem; align-items: center; margin-bottom: 1rem;">
                                <img src="${course.image}" alt="${course.title}" style="width: 80px; height: 60px; object-fit: cover; border-radius: 8px;">
                                <div style="flex: 1;">
                                    <h4 style="margin: 0; color: #333;">${course.title}</h4>
                                    <p style="margin: 0.5rem 0 0 0; color: #666; font-size: 0.9rem;">Acceso de por vida • Certificado incluido</p>
                                </div>
                            </div>
                            
                            <div style="display: flex; justify-content: space-between; align-items: center; padding-top: 1rem; border-top: 1px solid #e9ecef;">
                                <div>
                                    <span style="text-decoration: line-through; color: #999; margin-right: 0.5rem;">$${course.originalPrice}</span>
                                    <span style="font-size: 1.5rem; font-weight: bold; color: #28a745;">$${course.price}</span>
                                </div>
                                <div style="background: #28a745; color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.8rem; font-weight: 600;">
                                    ${course.discount}% OFF
                                </div>
                            </div>
                        </div>
                        
                        <div class="form-group">
                            <label style="display: block; margin-bottom: 0.5rem; font-weight: 600; color: #333;">Método de Pago</label>
                            <select id="paymentMethod" style="width: 100%; padding: 1rem; border: 2px solid #e9ecef; border-radius: 8px; font-size: 1rem;">
                                <option value="card">Tarjeta de Crédito/Débito</option>
                                <option value="transfer">Transferencia Bancaria</option>
                                <option value="paypal">PayPal</option>
                                <option value="mobile">Pago Móvil (Venezuela)</option>
                            </select>
                        </div>
                        
                        <div class="form-group">
                            <label style="display: block; margin-bottom: 0.5rem; font-weight: 600; color: #333;">Correo Electrónico</label>
                            <input type="email" id="purchaseEmail" placeholder="tu@email.com" style="width: 100%; padding: 1rem; border: 2px solid #e9ecef; border-radius: 8px; font-size: 1rem;">
                        </div>
                        
                        <div style="display: flex; gap: 1rem;">
                            <button type="button" class="btn btn-outline" style="flex: 1;" onclick="closePurchaseModal()">Cancelar</button>
                            <button type="button" class="btn btn-primary" style="flex: 1;" onclick="processPurchase()">
                                <span class="material-symbols-outlined" style="font-size: 1.2rem; vertical-align: middle; margin-right: 0.5rem;">lock</span>
                                Pagar $${course.price}
                            </button>
                        </div>
                        
                        <div style="text-align: center; margin-top: 1rem;">
                            <small style="color: #666;">
                                <span class="material-symbols-outlined" style="font-size: 1rem; vertical-align: middle; margin-right: 0.25rem;">security</span>
                                Compra segura y encriptada
                            </small>
                        </div>
                    </div>
                </div>
            `;
            
            // Add modal to body
            const modalContainer = document.createElement('div');
            modalContainer.innerHTML = modalHtml;
            document.body.appendChild(modalContainer);
            document.body.style.overflow = 'hidden';
        }

        function closePurchaseModal() {
            const modal = document.getElementById('purchaseModal');
            if (modal) {
                modal.remove();
                document.body.style.overflow = 'auto';
            }
        }

        function processPurchase() {
            const paymentMethod = document.getElementById('paymentMethod').value;
            const email = document.getElementById('purchaseEmail').value;
            
            if (!email) {
                showNotification('Por favor ingresa tu correo electrónico', 'error');
                return;
            }
            
            // Simulate processing
            const button = event.target;
            const originalText = button.innerHTML;
            button.innerHTML = '<span class="material-symbols-outlined" style="font-size: 1.2rem; vertical-align: middle; margin-right: 0.5rem;">hourglass_empty</span> Procesando...';
            button.disabled = true;
            
            setTimeout(() => {
                purchaseCount++;
                closePurchaseModal();
                showPurchaseSuccess();
                button.innerHTML = originalText;
                button.disabled = false;
            }, 2000);
        }

        function showPurchaseSuccess() {
            const successHtml = `
                <div id="successModal" class="modal active">
                    <div class="modal-content" style="max-width: 500px; text-align: center;">
                        <div style="color: #28a745; font-size: 4rem; margin-bottom: 1rem;">
                            <span class="material-symbols-outlined" style="font-size: 4rem;">check_circle</span>
                        </div>
                        <h2 style="color: #333; font-size: 2rem; margin-bottom: 1rem; font-weight: bold;">¡Compra Exitosa!</h2>
                        <p style="color: #666; font-size: 1.1rem; margin-bottom: 2rem;">Tu compra ha sido procesada exitosamente. Revisa tu correo para acceder al curso.</p>
                        
                        <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 12px; margin-bottom: 2rem;">
                            <h4 style="margin-bottom: 1rem; color: #333;">Resumen de la Compra</h4>
                            <div style="text-align: left;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span><%= course.title %></span>
                                    <span style="font-weight: bold;">$<%= course.price %></span>
                                </div>
                                <% if (course.discount > 0) { %>
                                    <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                        <span>Descuento (<%= course.discount %>%)</span>
                                        <span style="color: #28a745;">-$<%= (course.originalPrice - course.price).toFixed(2) %></span>
                                    </div>
                                <% } %>
                                <div style="display: flex; justify-content: space-between; padding-top: 0.5rem; border-top: 1px solid #e9ecef; font-weight: bold;">
                                    <span>Total</span>
                                    <span style="color: #28a745;">$<%= course.price %></span>
                                </div>
                            </div>
                        </div>
                        
                        <div style="display: flex; gap: 1rem;">
                            <button class="btn btn-primary" style="flex: 1;" onclick="closeSuccessModal()">
                                <span class="material-symbols-outlined" style="font-size: 1.2rem; vertical-align: middle; margin-right: 0.5rem;">play_arrow</span>
                                Comenzar Curso
                            </button>
                            <button class="btn btn-outline" style="flex: 1;" onclick="closeSuccessModal()">
                                <span class="material-symbols-outlined" style="font-size: 1.2rem; vertical-align: middle; margin-right: 0.5rem;">receipt</span>
                                Ver Recibo
                            </button>
                        </div>
                    </div>
                </div>
            `;
            
            const modalContainer = document.createElement('div');
            modalContainer.innerHTML = successHtml;
            document.body.appendChild(modalContainer);
        }

        function closeSuccessModal() {
            const modal = document.getElementById('successModal');
            if (modal) {
                modal.remove();
                document.body.style.overflow = 'auto';
            }
        }

        function updateCartCount() {
            // Update cart count display if exists
            const cartCount = document.querySelector('.cart-count');
            if (cartCount) {
                cartCount.textContent = cart.length;
            }
        }

        function updateCartButton() {
            // Update cart button text if exists
            const cartButton = document.querySelector('[onclick="addToCart()"]');
            if (cartButton && cart.length > 0) {
                cartButton.textContent = `Ver Carrito (${cart.length})`;
                cartButton.onclick = viewCart;
            }
        }

        function viewCart() {
            showNotification(`Tienes ${cart.length} curso(s) en el carrito`, 'info');
        }

        function showNotification(message, type = 'info') {
            const notificationHtml = `
                <div id="notification" style="
                    position: fixed;
                    top: 20px;
                    right: 20px;
                    padding: 1rem 1.5rem;
                    border-radius: 8px;
                    color: white;
                    font-weight: 500;
                    z-index: 10001;
                    opacity: 0;
                    transform: translateX(100%);
                    transition: all 0.3s ease;
                    max-width: 400px;
                    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
                    ${type === 'success' ? 'background: linear-gradient(135deg, #28a745, #20c997);' : ''}
                    ${type === 'error' ? 'background: linear-gradient(135deg, #dc3545, #c82333);' : ''}
                    ${type === 'warning' ? 'background: linear-gradient(135deg, #ffc107, #ff8f00);' : ''}
                    ${type === 'info' ? 'background: linear-gradient(135deg, #667eea, #764ba2);' : ''}
                ">
                    <div style="display: flex; align-items: center;">
                        <span class="material-symbols-outlined" style="margin-right: 0.75rem;">
                            ${type === 'success' ? 'check_circle' : ''}
                            ${type === 'error' ? 'error' : ''}
                            ${type === 'warning' ? 'warning' : ''}
                            ${type === 'info' ? 'info' : ''}
                        </span>
                        <span>${message}</span>
                    </div>
                </div>
            `;
            
            // Remove existing notification if any
            const existingNotification = document.getElementById('notification');
            if (existingNotification) {
                existingNotification.remove();
            }
            
            // Add new notification
            const notificationContainer = document.createElement('div');
            notificationContainer.innerHTML = notificationHtml;
            document.body.appendChild(notificationContainer);
            
            // Animate in
            setTimeout(() => {
                const notification = document.getElementById('notification');
                if (notification) {
                    notification.style.opacity = '1';
                    notification.style.transform = 'translateX(0)';
                }
            }, 100);
            
            // Remove after 4 seconds
            setTimeout(() => {
                const notification = document.getElementById('notification');
                if (notification) {
                    notification.style.opacity = '0';
                    notification.style.transform = 'translateX(100%)';
                    setTimeout(() => notification.remove(), 300);
                }
            }, 4000);
        }
    </script>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h3>Sobre EduConecta</h3>
                    <p>Plataforma educativa líder en Venezuela, comprometida con la formación de calidad accesible para todos.</p>
                </div>
                <div class="footer-section">
                    <h3>Enlaces Rápidos</h3>
                    <ul>
                        <li><a href="/catalogo">Catálogo de Cursos</a></li>
                        <li><a href="/precios">Planes y Precios</a></li>
                        <li><a href="/blog">Blog Educativo</a></li>
                        <li><a href="/contacto">Soporte</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h3>Contacto</h3>
                    <ul>
                        <li><i class="material-icons">email</i> info@educonecta.edu.ve</li>
                        <li><i class="material-icons">phone</i> +58 414-123-4567</li>
                        <li><i class="material-icons">place</i> Caracas, Venezuela</li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h3>Síguenos</h3>
                    <ul>
                        <li><a href="#">Facebook</a></li>
                        <li><a href="#">Instagram</a></li>
                        <li><a href="#">LinkedIn</a></li>
                        <li><a href="#">YouTube</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2024 EduConecta. Todos los derechos reservados.</p>
            </div>
        </div>
    </footer>
</body>
</html>
