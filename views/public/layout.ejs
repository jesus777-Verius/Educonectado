<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'EduConecta' %> - Plataforma Educativa</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <!-- Header -->
    <header class="header">
        <nav class="container nav">
            <a href="/" class="logo"><i class="material-icons" style="vertical-align: middle; margin-right: 8px;">school</i> EduConecta</a>
            <ul class="nav-links">
                <li><a href="/">Inicio</a></li>
                <li><a href="/catalogo">Catálogo</a></li>
                <li><a href="/precios">Precios</a></li>
                <li><a href="/blog">Blog</a></li>
                <li><a href="/quienes-somos">Nosotros</a></li>
                <li><a href="/contacto">Contacto</a></li>
                <% if (user) { %>
                    <li><a href="/dashboard">Mi Panel</a></li>
                    <li><a href="/logout">Salir</a></li>
                <% } else { %>
                    <li><a href="/login" class="btn btn-outline">Iniciar Sesión</a></li>
                <li><a href="/register" class="btn btn-primary">Crear Cuenta</a></li>
                <% } %>
            </ul>
        </nav>
    </header>

    <!-- Main Content -->
    <main>
        <% if (success_msg.length > 0) { %>
            <div class="alert alert-success" style="background: #d4edda; color: #155724; padding: 1rem; margin: 1rem 0; border-radius: 6px;">
                <%= success_msg %>
            </div>
        <% } %>
        
        <% if (error_msg.length > 0) { %>
            <div class="alert alert-error" style="background: #f8d7da; color: #721c24; padding: 1rem; margin: 1rem 0; border-radius: 6px;">
                <%= error_msg %>
            </div>
        <% } %>

        <%- body %>
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h3>Sobre EduConecta</h3>
                    <p>Plataforma educativa líder en Venezuela, comprometida con la formación de calidad accesible para todos.</p>
                </div>
                <div class="footer-section">
                    <h3>Enlaces Rápidos</h3>
                    <ul>
                        <li><a href="/catalogo">Catálogo de Cursos</a></li>
                        <li><a href="/precios">Planes y Precios</a></li>
                        <li><a href="/blog">Blog Educativo</a></li>
                        <li><a href="/contacto">Soporte</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h3>Contacto</h3>
                    <ul>
                        <li><i class="material-icons" style="font-size: 16px; vertical-align: middle; margin-right: 4px;">email</i> info@educonecta.edu.ve</li>
                        <li><i class="material-icons" style="font-size: 16px; vertical-align: middle; margin-right: 4px;">phone</i> +58 414-123-4567</li>
                        <li><i class="material-icons" style="font-size: 16px; vertical-align: middle; margin-right: 4px;">location_on</i> Caracas, Venezuela</li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h3>Síguenos</h3>
                    <ul>
                        <li><a href="#"><i class="material-icons" style="font-size: 16px; vertical-align: middle; margin-right: 4px;">facebook</i> Facebook</a></li>
                        <li><a href="#"><i class="material-icons" style="font-size: 16px; vertical-align: middle; margin-right: 4px;">photo_camera</i> Instagram</a></li>
                        <li><a href="#"><i class="material-icons" style="font-size: 16px; vertical-align: middle; margin-right: 4px;">work</i> LinkedIn</a></li>
                        <li><a href="#"><i class="material-icons" style="font-size: 16px; vertical-align: middle; margin-right: 4px;">play_circle_filled</i> YouTube</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2024 EduConecta. Todos los derechos reservados.</p>
            </div>
        </div>
    </footer>
</body>
</html>
