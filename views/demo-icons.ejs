<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Demo Material Icons - EduConecta</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <style>
        .demo-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem;
        }
        
        .icon-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1.5rem;
            margin: 2rem 0;
        }
        
        .icon-card {
            background: white;
            border-radius: 12px;
            padding: 1.5rem;
            text-align: center;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            transition: transform 0.3s ease;
        }
        
        .icon-card:hover {
            transform: translateY(-5px);
        }
        
        .icon-demo {
            font-size: 3rem;
            color: #667eea;
            margin-bottom: 1rem;
        }
        
        .icon-name {
            font-weight: bold;
            color: #333;
            margin-bottom: 0.5rem;
        }
        
        .icon-category {
            font-size: 0.9rem;
            color: #666;
        }
        
        .section-title {
            font-size: 2rem;
            color: #333;
            margin: 2rem 0 1rem;
            text-align: center;
        }
        
        .demo-nav {
            background: white;
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 2rem;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        }
        
        .demo-nav ul {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            list-style: none;
            padding: 0;
            margin: 0;
        }
        
        .demo-nav a {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.75rem 1rem;
            background: #667eea;
            color: white;
            text-decoration: none;
            border-radius: 8px;
            transition: background 0.3s ease;
        }
        
        .demo-nav a:hover {
            background: #5a6fd8;
        }
        
        .demo-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 3rem 2rem;
            text-align: center;
            border-radius: 15px;
            margin-bottom: 2rem;
        }
        
        .demo-header h1 {
            font-size: 3rem;
            margin-bottom: 1rem;
        }
        
        .demo-header p {
            font-size: 1.2rem;
            opacity: 0.9;
        }
        
        @media (max-width: 768px) {
            .demo-container {
                padding: 1rem;
            }
            
            .demo-header h1 {
                font-size: 2rem;
            }
            
            .demo-header p {
                font-size: 1rem;
            }
            
            .icon-grid {
                grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
                gap: 1rem;
            }
            
            .icon-demo {
                font-size: 2rem;
            }
            
            .demo-nav ul {
                flex-direction: column;
            }
            
            .demo-nav a {
                justify-content: center;
            }
        }
    </style>
</head>
<body>
