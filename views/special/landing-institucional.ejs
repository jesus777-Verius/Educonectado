<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Soluciones Educativas para Instituciones - EduConecta</title>
    <link rel="stylesheet" href="/css/styles.css">
    <style>
        .hero-institutional {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 6rem 2rem;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        
        .hero-institutional::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="grain" width="100" height="100" patternUnits="userSpaceOnUse"><circle cx="25" cy="25" r="1" fill="rgba(255,255,255,0.1)"/><circle cx="75" cy="75" r="1" fill="rgba(255,255,255,0.1)"/></pattern></defs><rect width="100" height="100" fill="url(%23grain)"/></svg>');
            opacity: 0.3;
        }
        
        .hero-content {
            position: relative;
            z-index: 1;
            max-width: 800px;
            margin: 0 auto;
        }
        
        .hero-title {
            font-size: 3.5rem;
            margin-bottom: 1.5rem;
            font-weight: bold;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        }
        
        .hero-subtitle {
            font-size: 1.3rem;
            margin-bottom: 2rem;
            opacity: 0.9;
            line-height: 1.6;
        }
        
        .trust-badges {
            display: flex;
            justify-content: center;
            gap: 2rem;
            margin-top: 3rem;
            flex-wrap: wrap;
        }
        
        .trust-badge {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 15px;
            padding: 1rem 2rem;
            backdrop-filter: blur(10px);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .solutions-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 2rem;
            padding: 4rem 2rem;
            max-width: 1200px;
            margin: 0 auto;
        }
        
        .solution-card {
            background: white;
            border-radius: 15px;
            padding: 2rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border: 1px solid #f0f0f0;
        }
        
        .solution-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.15);
        }
        
        .solution-icon {
            font-size: 3rem;
            margin-bottom: 1rem;
            color: #667eea;
        }
        
        .solution-title {
            font-size: 1.5rem;
            margin-bottom: 1rem;
            color: #333;
        }
        
        .solution-description {
            color: #666;
            line-height: 1.6;
            margin-bottom: 1.5rem;
        }
        
        .solution-features {
            list-style: none;
            padding: 0;
        }
        
        .solution-features li {
            padding: 0.5rem 0;
            color: #555;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .solution-features li::before {
            content: '✓';
            color: #28a745;
            font-weight: bold;
        }
        
        .stats-section {
            background: #f8f9fa;
            padding: 4rem 2rem;
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 2rem;
            max-width: 1000px;
            margin: 0 auto;
            text-align: center;
        }
        
        .stat-item {
            background: white;
            padding: 2rem;
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        
        .stat-number {
            font-size: 3rem;
            font-weight: bold;
            color: #667eea;
            margin-bottom: 0.5rem;
        }
        
        .stat-label {
            color: #666;
            font-size: 1.1rem;
        }
        
        .cta-section {
            background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
            color: white;
            padding: 4rem 2rem;
            text-align: center;
        }
        
        .cta-title {
            font-size: 2.5rem;
            margin-bottom: 1rem;
            font-weight: bold;
        }
        
        .cta-description {
            font-size: 1.2rem;
            margin-bottom: 2rem;
            opacity: 0.9;
        }
        
        .demo-form {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 15px;
            padding: 2rem;
            backdrop-filter: blur(10px);
            max-width: 600px;
            margin: 0 auto;
        }
        
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-bottom: 1rem;
        }
        
        .form-group {
            text-align: left;
        }
        
        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 500;
        }
        
        .form-group input,
        .form-group select {
            width: 100%;
            padding: 0.75rem;
            border: 1px solid rgba(255,255,255,0.3);
            border-radius: 8px;
            background: rgba(255,255,255,0.9);
            color: #333;
        }
        
        .form-group.full-width {
            grid-column: 1 / -1;
        }
        
        .testimonials-section {
            padding: 4rem 2rem;
            background: #f8f9fa;
        }
        
        .testimonials-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 2rem;
            max-width: 1200px;
            margin: 0 auto;
        }
        
        .testimonial-card {
            background: white;
            padding: 2rem;
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            position: relative;
        }
        
        .testimonial-card::before {
            content: '"';
            position: absolute;
            top: 1rem;
            left: 1rem;
            font-size: 3rem;
            color: #667eea;
            opacity: 0.2;
        }
        
        .testimonial-text {
            margin-bottom: 1.5rem;
            color: #555;
            line-height: 1.6;
            font-style: italic;
        }
        
        .testimonial-author {
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        
        .author-avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: #667eea;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }
        
        .author-info {
            flex: 1;
        }
        
        .author-name {
            font-weight: bold;
            color: #333;
        }
        
        .author-title {
            color: #666;
            font-size: 0.9rem;
        }
        
        .author-institution {
            color: #667eea;
            font-size: 0.8rem;
            font-weight: 500;
        }
        
        @media (max-width: 768px) {
            .hero-title {
                font-size: 2.5rem;
            }
            
            .hero-subtitle {
                font-size: 1.1rem;
            }
            
            .form-row {
                grid-template-columns: 1fr;
            }
            
            .trust-badges {
                gap: 1rem;
            }
        }
    </style>
</head>
<body>
    <!-- Hero Section -->
    <section class="hero-institutional">
        <div class="hero-content">
            <h1 class="hero-title">Transforma la Educación de tu Institución</h1>
            <p class="hero-subtitle">
                Plataforma LMS líder en América Latina con soluciones integrales para 
                colegios, universidades y empresas educativas
            </p>
            
            <div class="trust-badges">
                <div class="trust-badge">
                    <span><i class="material-icons">school</i></span>
                    <span>500+ Instituciones</span>
                </div>
                <div class="trust-badge">
                    <span><i class="material-icons">people</i></span>
                    <span>50K+ Educadores</span>
                </div>
                <div class="trust-badge">
                    <span><i class="material-icons">school</i></span>
                    <span>1M+ Estudiantes</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Solutions Section -->
    <section class="solutions-grid">
        <div class="solution-card">
            <div class="solution-icon"><i class="material-icons">school</i></div>
            <h3 class="solution-title">Gestión Académica Integral</h3>
            <p class="solution-description">
                Control total sobre programas académicos, currículos y evaluaciones
            </p>
            <ul class="solution-features">
                <li>Diseño curricular flexible</li>
                <li>Sistema de calificaciones automatizado</li>
                <li>Seguimiento de progreso en tiempo real</li>
                <li>Generación de certificados digitales</li>
                <li>Integración con sistemas existentes</li>
            </ul>
        </div>

        <div class="solution-card">
            <div class="solution-icon"><i class="material-icons">people</i></div>
            <h3 class="solution-title">Administración de Usuarios</h3>
            <p class="solution-description">
                Gestión centralizada de estudiantes, docentes y personal administrativo
            </p>
            <ul class="solution-features">
                <li>Roles y permisos personalizables</li>
                <li>Importación masiva de usuarios</li>
                <li>Autenticación segura (SSO)</li>
                <li>Gestión de grupos y clases</li>
                <li>Portal de bienvenida personalizado</li>
            </ul>
        </div>

        <div class="solution-card">
            <div class="solution-icon"><i class="material-icons">payments</i></div>
            <h3 class="solution-title">Facturación y Pagos</h3>
            <p class="solution-description">
                Sistema completo para gestión financiera y procesamiento de pagos
            </p>
            <ul class="solution-features">
                <li>Múltiples métodos de pago</li>
                <li>Planes de pago flexibles</li>
                <li>Reportes financieros detallados</li>
                <li>Automatización de facturación</li>
                <li>Gestión de becas y descuentos</li>
            </ul>
        </div>

        <div class="solution-card">
            <div class="solution-icon"><i class="material-icons">bar_chart</i></div>
            <h3 class="solution-title">Analytics y Reportes</h3>
            <p class="solution-description">
                Insights detallados sobre rendimiento e interacción de estudiantes
            </p>
            <ul class="solution-features">
                <li>Dashboard en tiempo real</li>
                <li>Métricas de engagement</li>
                <li>Reportes personalizables</li>
                <li>Análisis predictivo</li>
                <li>Exportación a múltiples formatos</li>
            </ul>
        </div>

        <div class="solution-card">
            <div class="solution-icon"><i class="material-icons">security</i></div>
            <h3 class="solution-title">Seguridad y Cumplimiento</h3>
            <p class="solution-description">
                Protección de datos y cumplimiento de normativas educativas
            </p>
            <ul class="solution-features">
                <li>Cifrado de datos AES-256</li>
                <li>Backup automático diario</li>
                <li>Cumplimiento GDPR y LFPDPPP</li>
                <li>Control de acceso granular</li>
                <li>Auditoría completa de actividades</li>
            </ul>
        </div>

        <div class="solution-card">
            <div class="solution-icon"><i class="material-icons">rocket_launch</i></div>
            <h3 class="solution-title">Soporte y Capacitación</h3>
            <p class="solution-description">
                Acompañamiento continuo para maximizar el uso de la plataforma
            </p>
            <ul class="solution-features">
                <li>Soporte técnico 24/7</li>
                <li>Capacitación personalizada</li>
                <li>Base de conocimientos completa</li>
                <li>Comunidad de educadores</li>
                <li>Actualizaciones continuas</li>
            </ul>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
        <div class="stats-grid">
            <div class="stat-item">
                <div class="stat-number">99.9%</div>
                <div class="stat-label">Uptime Garantizado</div>
            </div>
            <div class="stat-item">
                <div class="stat-number">24/7</div>
                <div class="stat-label">Soporte Técnico</div>
            </div>
            <div class="stat-item">
                <div class="stat-number">500+</div>
                <div class="stat-label">Instituciones Confían</div>
            </div>
            <div class="stat-item">
                <div class="stat-number">1M+</div>
                <div class="stat-label">Estudiantes Activos</div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <h2 class="cta-title">Solicita una Demo Personalizada</h2>
        <p class="cta-description">
            Descubre cómo EduConecta puede transformar tu institución educativa
        </p>
        
        <form class="demo-form" onsubmit="handleDemoRequest(event)">
            <div class="form-row">
                <div class="form-group">
                    <label>Nombre Completo *</label>
                    <input type="text" required>
                </div>
                <div class="form-group">
                    <label>Email Institucional *</label>
                    <input type="email" required>
                </div>
            </div>
            
            <div class="form-row">
                <div class="form-group">
                    <label>Teléfono *</label>
                    <input type="tel" required>
                </div>
                <div class="form-group">
                    <label>Cargo *</label>
                    <input type="text" required>
                </div>
            </div>
            
            <div class="form-row">
                <div class="form-group">
                    <label>Institución *</label>
                    <input type="text" required>
                </div>
                <div class="form-group">
                    <label>Tipo de Institución *</label>
                    <select required>
                        <option value="">Selecciona...</option>
                        <option value="school">Colegio/Escuela</option>
                        <option value="university">Universidad</option>
                        <option value="corporate">Empresa/Corporativo</option>
                        <option value="government">Gubernamental</option>
                        <option value="ngo">ONG</option>
                    </select>
                </div>
            </div>
            
            <div class="form-row">
                <div class="form-group">
                    <label>Número de Estudiantes *</label>
                    <select required>
                        <option value="">Selecciona...</option>
                        <option value="small">Menos de 100</option>
                        <option value="medium">100-500</option>
                        <option value="large">500-2000</option>
                        <option value="xlarge">Más de 2000</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>País *</label>
                    <select required>
                        <option value="">Selecciona...</option>
                        <option value="mx">México</option>
                        <option value="es">España</option>
                        <option value="co">Colombia</option>
                        <option value="ar">Argentina</option>
                        <option value="pe">Perú</option>
                        <option value="other">Otro</option>
                    </select>
                </div>
            </div>
            
            <div class="form-group full-width">
                <label>Mensaje Adicional</label>
                <input type="text" placeholder="Cuéntanos sobre tus necesidades específicas...">
            </div>
            
            <div style="text-align: center; margin-top: 2rem;">
                <button type="submit" class="btn btn-primary" style="background: white; color: #28a745; padding: 1rem 3rem; font-size: 1.1rem; border: none; border-radius: 25px; font-weight: bold; cursor: pointer;">
                    <i class="material-icons">rocket_launch</i> Solicitar Demo
                </button>
            </div>
        </form>
    </section>

    <!-- Testimonials Section -->
    <section class="testimonials-section">
        <h2 style="text-align: center; font-size: 2.5rem; margin-bottom: 1rem; color: #333;">
            Lo que Dicen Nuestros Clientes
        </h2>
        <p style="text-align: center; color: #666; margin-bottom: 3rem;">
            Instituciones líderes confían en EduConecta para su transformación digital
        </p>
        
        <div class="testimonials-grid">
            <div class="testimonial-card">
                <p class="testimonial-text">
                    EduConecta transformó completamente nuestra forma de enseñar. 
                    La plataforma es intuitiva y el soporte es excepcional.
                </p>
                <div class="testimonial-author">
                    <div class="author-avatar">MR</div>
                    <div class="author-info">
                        <div class="author-name">Dr. María Rodríguez</div>
                        <div class="author-title">Rectora</div>
                        <div class="author-institution">Universidad Tecnológica de México</div>
                    </div>
                </div>
            </div>

            <div class="testimonial-card">
                <p class="testimonial-text">
                    La implementación fue rápida y los resultados se vieron desde el primer mes. 
                    Nuestros estudiantes están más comprometidos que nunca.
                </p>
                <div class="testimonial-author">
                    <div class="author-avatar">JG</div>
                    <div class="author-info">
                        <div class="author-name">Juan García</div>
                        <div class="author-title">Director Académico</div>
                        <div class="author-institution">Colegio Bilingüe Horizon</div>
                    </div>
                </div>
            </div>

            <div class="testimonial-card">
                <p class="testimonial-text">
                    El sistema de reportes nos ha permitido tomar decisiones basadas en datos. 
                    Es una herramienta indispensable para nuestra gestión.
                </p>
                <div class="testimonial-author">
                    <div class="author-avatar">LM</div>
                    <div class="author-info">
                        <div class="author-name">Laura Martínez</div>
                        <div class="author-title">Coordinadora de Tecnología</div>
                        <div class="author-institution">Instituto Educativo Moderno</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script>
        function handleDemoRequest(event) {
            event.preventDefault();
            
            // Collect form data
            const formData = new FormData(event.target);
            const data = Object.fromEntries(formData);
            
            // Show success message
            const form = event.target;
            form.innerHTML = `
                <div style="text-align: center; padding: 2rem;">
                    <div style="font-size: 3rem; margin-bottom: 1rem;"><i class="material-icons">check_circle</i></div>
                    <h3 style="color: white; margin-bottom: 1rem;">¡Solicitud Recibida!</h3>
                    <p style="color: rgba(255,255,255,0.9);">
                        Nos pondremos en contacto contigo dentro de las próximas 24 horas
                        para agendar tu demo personalizada.
                    </p>
                    <p style="margin-top: 1rem; opacity: 0.8;">
                        Revisa tu email para confirmación.
                    </p>
                </div>
            `;
            
            // Store in localStorage (in real app, this would be sent to server)
            const requests = JSON.parse(localStorage.getItem('demo_requests') || '[]');
            requests.push({
                ...data,
                timestamp: new Date().toISOString(),
                status: 'pending'
            });
            localStorage.setItem('demo_requests', JSON.stringify(requests));
            
            // Log for analytics
            console.log('Demo request submitted:', data);
        }
    </script>
</body>
</html>
