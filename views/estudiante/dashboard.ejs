<%- include('layout') %>

<style>
    /* Dashboard Styles */
    .dashboard-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 2rem;
    }
    
    /* Welcome Section */
    .welcome-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 2.5rem;
        border-radius: 16px;
        margin-bottom: 2rem;
        position: relative;
        overflow: hidden;
    }
    
    .welcome-header::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 400px;
        height: 400px;
        background: rgba(255,255,255,0.1);
        border-radius: 50%;
    }
    
    .welcome-content {
        position: relative;
        z-index: 2;
    }
    
    .welcome-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }
    
    .welcome-subtitle {
        font-size: 1.2rem;
        opacity: 0.9;
        margin-bottom: 2rem;
    }
    
    .welcome-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 2rem;
        margin-top: 2rem;
    }
    
    .welcome-stat {
        text-align: center;
        padding: 1rem;
        background: rgba(255,255,255,0.1);
        border-radius: 12px;
        backdrop-filter: blur(10px);
    }
    
    .stat-number {
        font-size: 2rem;
        font-weight: bold;
        margin-bottom: 0.5rem;
    }
    
    .stat-label {
        opacity: 0.9;
        font-size: 0.9rem;
    }
    
    /* Main Options Grid */
    .options-section {
        margin-bottom: 3rem;
    }
    
    .section-title {
        font-size: 1.8rem;
        font-weight: 600;
        color: #333;
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .options-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }
    
    .option-card {
        background: white;
        border-radius: 16px;
        padding: 2rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        cursor: pointer;
        text-decoration: none;
        color: inherit;
        position: relative;
        overflow: hidden;
    }
    
    .option-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: linear-gradient(90deg, #667eea, #764ba2);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.3s ease;
    }
    
    .option-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 40px rgba(102, 126, 234, 0.2);
    }
    
    .option-card:hover::before {
        transform: scaleX(1);
    }
    
    .option-icon {
        width: 80px;
        height: 80px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.5rem;
        font-size: 2rem;
        color: white;
        position: relative;
    }
    
    .option-icon::after {
        content: '';
        position: absolute;
        inset: -2px;
        border-radius: 22px;
        padding: 2px;
        background: linear-gradient(45deg, #667eea, #764ba2);
        -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        -webkit-mask-composite: exclude;
        mask-composite: exclude;
        opacity: 0.3;
    }
    
    .option-title {
        font-size: 1.3rem;
        font-weight: 600;
        color: #333;
        margin-bottom: 0.5rem;
    }
    
    .option-description {
        color: #666;
        line-height: 1.6;
        margin-bottom: 1rem;
    }
    
    .option-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.9rem;
        color: #999;
    }
    
    .option-badge {
        background: rgba(102, 126, 234, 0.1);
        color: #667eea;
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
    }
    
    /* Option Colors */
    .option-courses .option-icon { background: linear-gradient(135deg, #667eea, #764ba2); }
    .option-aula .option-icon { background: linear-gradient(135deg, #f093fb, #f5576c); }
    .option-calificaciones .option-icon { background: linear-gradient(135deg, #4facfe, #00f2fe); }
    .option-biblioteca .option-icon { background: linear-gradient(135deg, #43e97b, #38f9d7); }
    .option-progreso .option-icon { background: linear-gradient(135deg, #fa709a, #fee140); }
    .option-certificados .option-icon { background: linear-gradient(135deg, #30cfd0, #330867); }
    .option-perfil .option-icon { background: linear-gradient(135deg, #a8edea, #fed6e3); }
    .option-configuracion .option-icon { background: linear-gradient(135deg, #ff9a9e, #fecfef); }
    
    /* Quick Actions */
    .quick-actions {
        background: white;
        border-radius: 16px;
        padding: 2rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        margin-bottom: 2rem;
    }
    
    .quick-actions-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }
    
    .quick-actions-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: #333;
    }
    
    .quick-actions-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
    }
    
    .quick-action-btn {
        padding: 1rem;
        border: 2px solid #e9ecef;
        border-radius: 12px;
        background: white;
        text-align: center;
        transition: all 0.3s ease;
        cursor: pointer;
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
    }
    
    .quick-action-btn:hover {
        border-color: #667eea;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.15);
    }
    
    .quick-action-icon {
        font-size: 1.5rem;
        color: #667eea;
    }
    
    .quick-action-text {
        font-weight: 600;
        color: #333;
    }
    
    /* Recent Activity */
    .activity-section {
        background: white;
        border-radius: 16px;
        padding: 2rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    }
    
    .activity-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }
    
    .activity-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: #333;
    }
    
    .activity-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    
    .activity-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem;
        background: #f8f9fa;
        border-radius: 12px;
        border-left: 4px solid #667eea;
    }
    
    .activity-icon {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea, #764ba2);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1rem;
    }
    
    .activity-content {
        flex: 1;
    }
    
    .activity-title {
        font-weight: 600;
        color: #333;
        margin-bottom: 0.25rem;
    }
    
    .activity-description {
        color: #666;
        font-size: 0.9rem;
    }
    
    .activity-time {
        color: #999;
        font-size: 0.8rem;
    }
    
    /* Responsive */
    @media (max-width: 768px) {
        .dashboard-container {
            padding: 1rem;
        }
        
        .welcome-title {
            font-size: 1.8rem;
        }
        
        .options-grid {
            grid-template-columns: 1fr;
        }
        
        .quick-actions-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>

<div class="dashboard-container">
    <!-- Welcome Section -->
    <div class="welcome-header">
        <div class="welcome-content">
            <h1 class="welcome-title">¡Bienvenido de nuevo, <%= user.nombres %>!</h1>
            <p class="welcome-subtitle">Continúa tu camino hacia el éxito académico</p>
            <div class="welcome-stats">
                <div class="welcome-stat">
                    <div class="stat-number">12</div>
                    <div class="stat-label">Cursos en progreso</div>
                </div>
                <div class="welcome-stat">
                    <div class="stat-number">8</div>
                    <div class="stat-label">Cursos completados</div>
                </div>
                <div class="welcome-stat">
                    <div class="stat-number">95%</div>
                    <div class="stat-label">Promedio general</div>
                </div>

            <!-- 2. Aula Virtual -->
            <a href="/estudiante/aula" class="option-card option-aula">
                <div class="option-icon">
                    <span class="material-symbols-outlined">play_circle</span>
                </div>
                <h3 class="option-title">Aula Virtual</h3>
                <p class="option-description">Ingresa a tus clases en vivo y accede a materiales de estudio</p>
                <div class="option-meta">
                    <span class="option-badge">En vivo</span>
                    <span>2 clases hoy</span>
                </div>
            </a>

            <!-- 3. Calificaciones -->
            <a href="/estudiante/calificaciones" class="option-card option-calificaciones">
                <div class="option-icon">
                    <span class="material-symbols-outlined">grade</span>
                </div>
                <h3 class="option-title">Calificaciones</h3>
                <p class="option-description">Revisa tus notas, promedios y certificados obtenidos</p>
                <div class="option-meta">
                    <span class="option-badge">95% promedio</span>
                    <span>3 evaluaciones</span>
                </div>
            </a>

            <!-- 4. Biblioteca Virtual -->
            <a href="/estudiante/biblioteca" class="option-card option-biblioteca">
                <div class="option-icon">
                    <span class="material-symbols-outlined">library_books</span>
                </div>
                <h3 class="option-title">Biblioteca Virtual</h3>
                <p class="option-description">Explora libros, videos y recursos educativos digitales</p>
                <div class="option-meta">
                    <span class="option-badge">1,250+ recursos</span>
                    <span>45 categorías</span>
                </div>
            </a>

            <!-- 5. Mi Progreso -->
            <a href="/estudiante/progreso" class="option-card option-progreso">
                <div class="option-icon">
                    <span class="material-symbols-outlined">trending_up</span>
                </div>
                <h3 class="option-title">Mi Progreso</h3>
                <p class="option-description">Visualiza tu avance académico y estadísticas de aprendizaje</p>
                <div class="option-meta">
                    <span class="option-badge">78% completo</span>
                    <span>En buen ritmo</span>
                </div>
            </a>

            <!-- 6. Certificados -->
            <a href="/estudiante/certificados" class="option-card option-certificados">
                <div class="option-icon">
                    <span class="material-symbols-outlined">workspace_premium</span>
                </div>
                <h3 class="option-title">Certificados</h3>
                <p class="option-description">Descarga y comparte tus certificados de cursos completados</p>
                <div class="option-meta">
                    <span class="option-badge">8 obtenidos</span>
                    <span>2 en proceso</span>
                </div>
            </a>

            <!-- 7. Mi Perfil -->
            <a href="/estudiante/perfil" class="option-card option-perfil">
                <div class="option-icon">
                    <span class="material-symbols-outlined">person</span>
                </div>
                <h3 class="option-title">Mi Perfil</h3>
                <p class="option-description">Gestiona tu información personal y preferencias de cuenta</p>
                <div class="option-meta">
                    <span class="option-badge">Completo</span>
                    <span>Verificado</span>
                </div>
            </a>

            <!-- 8. Configuración -->
            <a href="/estudiante/configuracion" class="option-card option-configuracion">
                <div class="option-icon">
                    <span class="material-symbols-outlined">settings</span>
                </div>
                <h3 class="option-title">Configuración</h3>
                <p class="option-description">Personaliza tu experiencia y ajusta las preferencias del sistema</p>
                <div class="option-meta">
                    <span class="option-badge">Actualizado</span>
                    <span>Todo listo</span>
                </div>
            </a>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="quick-actions">
        <div class="quick-actions-header">
            <h3 class="quick-actions-title">Acciones Rápidas</h3>
        </div>
        <div class="quick-actions-grid">
            <a href="/estudiante/cursos" class="quick-action-btn">
                <span class="material-symbols-outlined quick-action-icon">add_circle</span>
                <span class="quick-action-text">Nuevo Curso</span>
            </a>
            <a href="/estudiante/aula" class="quick-action-btn">
                <span class="material-symbols-outlined quick-action-icon">videocam</span>
                <span class="quick-action-text">Unir a Clase</span>
            </a>
            <a href="/estudiante/calificaciones" class="quick-action-btn">
                <span class="material-symbols-outlined quick-action-icon">assessment</span>
                <span class="quick-action-text">Ver Notas</span>
            </a>
            <a href="/estudiante/biblioteca" class="quick-action-btn">
                <span class="material-symbols-outlined quick-action-icon">search</span>
                <span class="quick-action-text">Buscar Recursos</span>
            </a>
        </div>
    </div>

    <!-- Recent Activity -->
    <div class="activity-section">
        <div class="activity-header">
            <h3 class="activity-title">Actividad Reciente</h3>
        </div>
        <div class="activity-list">
            <div class="activity-item">
                <div class="activity-icon">
                    <span class="material-symbols-outlined">menu_book</span>
                </div>
                <div class="activity-content">
                    <div class="activity-title">Completaste la lección "SEO Avanzado"</div>
                    <div class="activity-description">Marketing Digital Completo - Módulo 5</div>
                </div>
                <div class="activity-time">Hace 2 horas</div>
            </div>
            <div class="activity-item">
                <div class="activity-icon">
                    <span class="material-symbols-outlined">grade</span>
                </div>
                <div class="activity-content">
                    <div class="activity-title">Nueva calificación disponible</div>
                    <div class="activity-description">Examen final de Desarrollo Web - 92/100</div>
                </div>
                <div class="activity-time">Hace 5 horas</div>
            </div>
            <div class="activity-item">
                <div class="activity-icon">
                    <span class="material-symbols-outlined">workspace_premium</span>
                </div>
                <div class="activity-content">
                    <div class="activity-title">Certificado emitido</div>
                    <div class="activity-description">Fundamentos de Marketing Digital - Completado</div>
                </div>
                <div class="activity-time">Ayer</div>
            </div>
        </div>
    </div>
</div>

<!-- Footer -->
<footer class="dashboard-footer">
    <div class="container">
        <p>&copy; 2024 EduConecta. Panel Estudiantil</p>
    </div>
</footer>
</body>
</html>
