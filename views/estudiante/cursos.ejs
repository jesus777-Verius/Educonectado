<!-- Course Details Modal -->
<div class="modal" id="courseModal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 id="modalCourseTitle">Marketing Digital Completo</h2>
            <button class="modal-close" onclick="closeModal()">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="modal-body">
            <div class="course-tabs">
                <button class="tab-btn active" onclick="switchTab('overview')">Descripción</button>
                <button class="tab-btn" onclick="switchTab('curriculum')">Contenido</button>
                <button class="tab-btn" onclick="switchTab('instructor')">Instructor</button>
                <button class="tab-btn" onclick="switchTab('reviews')">Reseñas</button>
            </div>
            
            <div class="tab-content active" id="overview">
                <h3>Descripción del Curso</h3>
                <p>Este curso completo de marketing digital te enseñará todas las estrategias y herramientas necesarias para tener éxito en el mundo digital.</p>
                <h4>¿Qué aprenderás?</h4>
                <ul>
                    <li>SEO y SEM para posicionamiento web</li>
                    <li>Marketing en redes sociales</li>
                    <li>Email marketing automatizado</li>
                    <li>Analítica web y métricas</li>
                    <li>Creación de contenido digital</li>
                </ul>
            </div>
            
            <div class="tab-content" id="curriculum">
                <h3>Contenido del Curso</h3>
                <div class="lesson-list">
                    <div class="lesson-item completed">
                        <div class="lesson-icon">
                            <span class="material-symbols-outlined">check</span>
                        </div>
                        <div class="lesson-content">
                            <div class="lesson-title">Introducción al Marketing Digital</div>
                            <div class="lesson-duration">45 minutos</div>
                        </div>
                        <div class="lesson-status">Completado</div>
                    </div>
                    <div class="lesson-item completed">
                        <div class="lesson-icon">
                            <span class="material-symbols-outlined">check</span>
                        </div>
                        <div class="lesson-content">
                            <div class="lesson-title">Fundamentos de SEO</div>
                            <div class="lesson-duration">60 minutos</div>
                        </div>
                        <div class="lesson-status">Completado</div>
                    </div>
                    <div class="lesson-item">
                        <div class="lesson-icon">
                            <span class="material-symbols-outlined">play_arrow</span>
                        </div>
                        <div class="lesson-content">
                            <div class="lesson-title">SEO Avanzado</div>
                            <div class="lesson-duration">90 minutos</div>
                        </div>
