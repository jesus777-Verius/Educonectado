                <div class="course-actions">
                    <button class="btn btn-primary" onclick="continueCourse(1)">
                        <span class="material-symbols-outlined" style="font-size: 1rem;">play_arrow</span>
                        Continuar
                    </button>
                    <button class="btn btn-outline" onclick="viewCourseDetails(1)">
                        <span class="material-symbols-outlined" style="font-size: 1rem;">info</span>
                        Detalles
                    </button>
                </div>
            </div>
        </div>

        <div class="course-card" data-category="development" data-status="active" data-title="desarrollo web moderno">
            <div class="course-image">
                <span class="material-symbols-outlined">code</span>
                <div class="course-badge">En Progreso</div>
                <div class="course-progress">
                    <div class="progress-info">
                        <span>Progreso</span>
                        <span>45%</span>
                    </div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: 45%;"></div>
                    </div>
                </div>
            </div>
            <div class="course-content">
                <h3 class="course-title">Desarrollo Web Moderno</h3>
