                <div class="course-actions">
                    <button class="btn btn-primary" onclick="continueCourse(2)">
                        <span class="material-symbols-outlined" style="font-size: 1rem;">play_arrow</span>
                        Continuar
                    </button>
                    <button class="btn btn-outline" onclick="viewCourseDetails(2)">
