                    <span class="material-symbols-outlined" style="font-size: 1rem;">person</span>
                    Prof. Ana Martínez
                </div>
                <div class="course-meta">
                    <div class="meta-item">
                        <span class="material-symbols-outlined" style="font-size: 1rem;">schedule</span>
                        16 semanas
                    </div>
                    <div class="meta-item">
                        <span class="material-symbols-outlined" style="font-size: 1rem;">video_library</span>
                        64 lecciones
                    </div>
                    <div class="meta-item">
                        <span class="material-symbols-outlined" style="font-size: 1rem;">star</span>
                        4.9/5
                    </div>
                </div>
