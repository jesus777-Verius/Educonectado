<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Soporte - EduConecta</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
    <!-- Dashboard Header -->
    <header class="dashboard-header">
        <div class="container">
            <div class="dashboard-nav">
                <div class="nav-left">
                    <a href="/" class="logo"><i class="material-icons">menu_book</i> EduConecta</a>
                    <span class="user-role">Estudiante</span>
                </div>
                <div class="nav-right">
                    <div class="notifications">
                        <button class="btn-icon"><i class="material-icons">notifications</i> <span class="badge">3</span></button>
                    </div>
                    <div class="user-menu">
                        <img src="https://via.placeholder.com/40x40/667eea/ffffff?text=J" alt="Usuario" class="user-avatar">
                        <span>Juan Pérez</span>
                        <div class="dropdown">
                            <a href="/estudiante/perfil">Mi Perfil</a>
                            <a href="/estudiante/configuracion">Configuración</a>
                            <a href="/estudiante/soporte">Soporte</a>
                            <a href="/logout">Cerrar Sesión</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Dashboard Content -->
    <div class="dashboard-container">
        <!-- Sidebar -->
        <aside class="dashboard-sidebar">
            <nav class="sidebar-nav">
                <ul>
                    <li><a href="/estudiante/dashboard"><i class="material-icons">bar_chart</i> Dashboard</a></li>
                    <li><a href="/estudiante/cursos"><i class="material-icons">menu_book</i> Mis Cursos</a></li>
                    <li><a href="/estudiante/aula"><i class="material-icons">school</i> Mi Aula Virtual</a></li>
                    <li><a href="/estudiante/progreso"><i class="material-icons">show_chart</i> Progreso</a></li>
                    <li><a href="/estudiante/calificaciones"><i class="material-icons">my_location</i> Calificaciones</a></li>
                    <li><a href="/estudiante/biblioteca"><i class="material-icons">local_library</i> Biblioteca</a></li>
                    <li><a href="/estudiante/foros"><i class="material-icons">forum</i> Foros</a></li>
                    <li><a href="/estudiante/certificados"><i class="material-icons">emoji_events</i> Certificados</a></li>
                    <li><a href="/estudiante/recomendados"><i class="material-icons">star</i> Recomendados</a></li>
                </ul>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="dashboard-main">
            <!-- Header -->
            <div class="dashboard-card">
                <h1>🛠️ Centro de Soporte</h1>
                <p>Estamos aquí para ayudarte con cualquier duda o problema</p>
            </div>

            <!-- Quick Actions -->
            <div class="dashboard-card">
                <h2>⚡ Acciones Rápidas</h2>
                <div class="stats-grid">
                    <div class="stat-card" style="cursor: pointer;">
                        <div class="stat-icon blue"><i class="material-icons">edit</i></div>
                        <div class="stat-info">
                            <h3>Crear Ticket</h3>
                            <p>Reportar un problema</p>
                        </div>
                    </div>
                    <div class="stat-card" style="cursor: pointer;">
                        <div class="stat-icon green"><i class="material-icons">forum</i></div>
                        <div class="stat-info">
                            <h3>Chat en Vivo</h3>
                            <p>Soporte inmediato</p>
                        </div>
                    </div>
                    <div class="stat-card" style="cursor: pointer;">
                        <div class="stat-icon orange"><i class="material-icons">menu_book</i></div>
                        <div class="stat-info">
                            <h3>Guías</h3>
                            <p>Documentación</p>
                        </div>
                    </div>
                    <div class="stat-card" style="cursor: pointer;">
                        <div class="stat-icon red">📞</div>
                        <div class="stat-info">
                            <h3>Llamar</h3>
                            <p>Soporte telefónico</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Help Categories -->
            <div class="dashboard-card">
                <h2>📂 Categorías de Ayuda</h2>
                <div class="course-grid">
                    <div class="course-card">
                        <div style="padding: 1.5rem; text-align: center;">
                            <div style="font-size: 3rem; margin-bottom: 1rem;"><i class="material-icons">menu_book</i></div>
                            <h3 style="margin-bottom: 1rem;">Cursos y Aprendizaje</h3>
                            <p style="color: #666; font-size: 0.9rem; margin-bottom: 1rem;">Acceso a cursos, progreso, certificados</p>
                            <button class="btn btn-outline">Ver Ayuda</button>
                        </div>
                    </div>
                    <div class="course-card">
                        <div style="padding: 1.5rem; text-align: center;">
                            <div style="font-size: 3rem; margin-bottom: 1rem;">💳</div>
                            <h3 style="margin-bottom: 1rem;">Pagos y Suscripciones</h3>
                            <p style="color: #666; font-size: 0.9rem; margin-bottom: 1rem;">Facturación, métodos de pago, reembolsos</p>
                            <button class="btn btn-outline">Ver Ayuda</button>
                        </div>
                    </div>
                    <div class="course-card">
                        <div style="padding: 1.5rem; text-align: center;">
                            <div style="font-size: 3rem; margin-bottom: 1rem;">🔐</div>
                            <h3 style="margin-bottom: 1rem;">Cuenta y Seguridad</h3>
                            <p style="color: #666; font-size: 0.9rem; margin-bottom: 1rem;">Inicio de sesión, perfil, privacidad</p>
                            <button class="btn btn-outline">Ver Ayuda</button>
                        </div>
                    </div>
                    <div class="course-card">
                        <div style="padding: 1.5rem; text-align: center;">
                            <div style="font-size: 3rem; margin-bottom: 1rem;">🎥</div>
                            <h3 style="margin-bottom: 1rem;">Problemas Técnicos</h3>
                            <p style="color: #666; font-size: 0.9rem; margin-bottom: 1rem;">Videos, descargas, plataforma</p>
                            <button class="btn btn-outline">Ver Ayuda</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- FAQ Section -->
