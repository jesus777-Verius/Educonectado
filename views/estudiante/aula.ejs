    }

    // Progress Functions
    function updateProgress() {
        const completedLessons = document.querySelectorAll('.lesson-item.completed').length;
        const totalLessons = document.querySelectorAll('.lesson-item').length;
        const percentage = Math.round((completedLessons / totalLessons) * 100);
        
        // Update header progress
        document.querySelector('.progress-percentage').textContent = percentage + '%';
        document.querySelector('.progress-fill').style.width = percentage + '%';
        
        // Update sidebar progress
        const sidebarProgress = document.querySelector('.sidebar-card:last-child .sidebar-content');
        sidebarProgress.innerHTML = `
            <div style="display: flex; flex-direction: column; gap: 1rem;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
