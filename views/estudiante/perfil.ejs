<script>
    let isEditMode = false;

    function toggleEditMode() {
        isEditMode = !isEditMode;
        const inputs = document.querySelectorAll('#profileForm input:not([disabled]), #profileForm textarea');
        const formActions = document.getElementById('formActions');
        
        inputs.forEach(input => {
            input.disabled = !isEditMode;
        });
        
        formActions.style.display = isEditMode ? 'block' : 'none';
    }

    function cancelEdit() {
        isEditMode = false;
        toggleEditMode();
        // Reset form values to original
        document.getElementById('nombres').value = '<%= user.nombres %>';
        document.getElementById('apellidos').value = '<%= user.apellidos %>';
        document.getElementById('email').value = '<%= user.email %>';
        document.getElementById('telefono').value = '<%= user.telefono %>';
    }

    function editProfile() {
        toggleEditMode();
    }

    function shareProfile() {
        // Create shareable link
        const shareUrl = window.location.origin + '/estudiante/perfil';
        
        if (navigator.share) {
            navigator.share({
                title: 'Mi Perfil - EduConecta',
                text: 'Mira mi perfil de estudiante en EduConecta',
                url: shareUrl
            });
        } else {
            // Fallback: copy to clipboard
            navigator.clipboard.writeText(shareUrl).then(() => {
                showNotification('Enlace copiado al portapapeles');
            });
        }
    }

    function handleAvatarChange(event) {
        const file = event.target.files[0];
        if (file) {
            // Preview avatar
            const reader = new FileReader();
            reader.onload = function(e) {
                document.querySelector('.profile-avatar').src = e.target.result;
                showNotification('Avatar actualizado correctamente');
            };
            reader.readAsDataURL(file);
            
            // Here you would upload the file to the server
            // uploadAvatar(file);
        }
    }

    function showNotification(message) {
        // Create notification element
        const notification = document.createElement('div');
        notification.className = 'alert alert-success';
        notification.textContent = message;
        notification.style.cssText = 'position: fixed; top: 20px; right: 20px; z-index: 9999; animation: slideIn 0.3s ease;';
        
        document.body.appendChild(notification);
        
        // Remove after 3 seconds
        setTimeout(() => {
            notification.remove();
        }, 3000);
    }

    // Handle form submission
    document.getElementById('profileForm').addEventListener('submit', function(e) {
        e.preventDefault();
        
        // Get form data
        const formData = {
            nombres: document.getElementById('nombres').value,
            apellidos: document.getElementById('apellidos').value,
            email: document.getElementById('email').value,
            telefono: document.getElementById('telefono').value,
            biografia: document.getElementById('biografia').value
        };
        
        // Here you would send the data to the server
        console.log('Saving profile:', formData);
        
        // Show success message
        showNotification('Perfil actualizado correctamente');
        
        // Exit edit mode
        isEditMode = false;
        toggleEditMode();
    });

    // Animate progress bars on page load
    document.addEventListener('DOMContentLoaded', function() {
        const progressBars = document.querySelectorAll('.progress-fill');
        progressBars.forEach(bar => {
            const width = bar.style.width;
            bar.style.width = '0';
            setTimeout(() => {
                bar.style.width = width;
            }, 500);
        });
    });
</script>
