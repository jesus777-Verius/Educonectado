            <!-- Learning Goals -->
            <div class="dashboard-card">
                <h2><i class="material-icons">my_location</i> Metas de Aprendizaje</h2>
                <div class="course-grid">
                    <div class="course-card">
                        <div style="padding: 1.5rem;">
                            <h3 style="margin-bottom: 1rem;">Meta Semanal</h3>
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span>Completar 5 lecciones</span>
                                    <span style="color: #667eea; font-weight: bold;">3/5</span>
                                </div>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 60%;"></div>
                                </div>
                            </div>
                            <div style="margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span>Estudiar 10 horas</span>
                                    <span style="color: #667eea; font-weight: bold;">7/10</span>
