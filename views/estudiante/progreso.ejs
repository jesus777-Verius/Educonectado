                                            <div style="font-weight: bold;">Excel Avanzado</div>
                                            <div style="font-size: 0.8rem; color: #666;">20 lecciones</div>
                                        </div>
                                    </div>
                                </td>
                                <td style="padding: 1rem; text-align: center;">20</td>
                                <td style="padding: 1rem; text-align: center;">20</td>
                                <td style="padding: 1rem; text-align: center;">
                                    <div style="color: #28a745; font-weight: bold;">100%</div>
                                    <div class="progress-bar" style="height: 4px;">
                                        <div class="progress-fill" style="width: 100%; background: #28a745;"></div>
                                    </div>
                                </td>
                                <td style="padding: 1rem; text-align: center;">16h</td>
                                <td style="padding: 1rem; text-align: center;">
                                    <span style="background: #28a745; color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.8rem;">Completado</span>
