                                <td style="padding: 1rem; text-align: center;">
                                    <span style="background: #ffc107; color: #000; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.8rem;">En Progreso</span>
                                </td>
                            </tr>
                            <tr style="border-bottom: 1px solid #f0f0f0;">
                                <td style="padding: 1rem;">
                                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                                        <img src="https://via.placeholder.com/40x40/764ba2/ffffff?text=P" alt="Curso" style="width: 40px; height: 40px; border-radius: 8px;">
                                        <div>
                                            <div style="font-weight: bold;">Programación Web</div>
                                            <div style="font-size: 0.8rem; color: #666;">24 lecciones</div>
                                        </div>
                                    </div>
                                </td>
                                <td style="padding: 1rem; text-align: center;">24</td>
                                <td style="padding: 1rem; text-align: center;">11</td>
                                <td style="padding: 1rem; text-align: center;">
                                    <div style="color: #667eea; font-weight: bold;">45%</div>
                                    <div class="progress-bar" style="height: 4px;">
                                        <div class="progress-fill" style="width: 45%;"></div>
                                    </div>
                                </td>
                                <td style="padding: 1rem; text-align: center;">9h</td>
                                <td style="padding: 1rem; text-align: center;">
                                    <span style="background: #ffc107; color: #000; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.8rem;">En Progreso</span>
                                </td>
                            </tr>
                            <tr style="border-bottom: 1px solid #f0f0f0;">
                                <td style="padding: 1rem;">
                                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                                        <img src="https://via.placeholder.com/40x40/28a745/ffffff?text=E" alt="Curso" style="width: 40px; height: 40px; border-radius: 8px;">
