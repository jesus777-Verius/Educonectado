                        <div style="position: absolute; left: -1.5rem; top: 0.5rem; width: 12px; height: 12px; background: #dc3545; border-radius: 50%; border: 2px solid white;"></div>
                        <div style="background: #f8f9fa; padding: 1rem; border-radius: 8px; border-left: 3px solid #dc3545;">
                            <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                <strong>Curso Iniciado: Marketing Digital</strong>
